@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Detalle";
}


<h2 class="display-4 text-center">Cuentas</h2>
<div>
    <h3 class="text-muted font-weight-light">Detalle</h3>
    <hr />
    <div class="col-sm-8 table-responsive">
        <table class="mx-auto table-borderless table-hover tabla-detalle">
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Usuario)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Usuario)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Password)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Password)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Empresa)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Empresa)
                </td>
            </tr>


        </table>
    </div>

    <div class="form-group col-md-9 mx-auto my-5">
        @Html.ActionLink("Volver a la lista", "Index",null, new { @class = "btn btn-block btn-danger mt-3" })
    </div>
</div>