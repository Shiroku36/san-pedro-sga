@model IEnumerable<ControlPersonalAppWeb.Vacaciones>

@{
    ViewBag.Title = "Índice";
}

@if (ViewBag.trabajador.Id != 0)
{
    <a href='@Url.Action("Create", "Vacaciones", new { id = ViewBag.trabajador.Id })'>
        <button type="button" class="btn btn-default">Crear nuevo</button>
    </a>
}
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Año)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Normales)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Progresivas)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Total)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.TomadasNormales)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.TomadasProgresivas)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Saldo)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Año)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Normales)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Progresivas)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Total)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TomadasNormales)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TomadasProgresivas)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Saldo)
            </td>
            <td>
                <a href='@Url.Action("Edit", "Vacaciones", new { id = item.Id })'>
                    <button type="button" class="btn btn-default">Editar</button>
                </a>
                <a href='@Url.Action("Details", "Vacaciones", new { id = item.Id })'>
                    <button type="button" class="btn btn-default">Detalle</button>
                </a>
                <a href='@Url.Action("Delete", "Vacaciones", new { id = item.Id })'>
                    <button type="button" class="btn btn-default" })>Borrar</button>
                </a>
            </td>
        </tr>
    }

</table>
