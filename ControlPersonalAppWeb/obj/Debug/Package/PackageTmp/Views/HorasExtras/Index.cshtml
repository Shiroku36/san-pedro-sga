@model IEnumerable<ControlPersonalAppWeb.HorasExtras>

@{
    ViewBag.Title = "Horas extras";
}

@if (ViewBag.trabajador.Id != 0)
{
    <a href='@Url.Action("Create", "HorasExtras", new { id = ViewBag.trabajador.Id })'>
        <button type="button" class="btn btn-primary float-right mb-3">Crear nuevo</button>
    </a>
}

@if (!string.IsNullOrEmpty(ViewBag.trabajador.Nombre))
{
    <div class="table-responsive">
        <table class="table">
            <tr class="bg-primary">
                <th>
                    @Html.DisplayNameFor(model => model.Horas)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Porcentaje)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Periodo)
                </th>
                <th>Accion</th>
            </tr>


            @foreach (var item in Model)
            {

                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Horas)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Porcentaje)
                    </td>
                    <td>
                        @item.Periodo.Value.ToString("MM-yyyy")
                    </td>
                    <td>
                        <a href='@Url.Action("Edit", "HorasExtras", new { id = item.Id })'>
                            <button type="button" class="btn btn-warning">Editar</button>
                        </a>
                        <a href='@Url.Action("Details", "HorasExtras", new { id = item.Id })'>
                            <button type="button" class="btn btn-info">Detalle</button>
                        </a>
                        <a href='@Url.Action("Delete", "HorasExtras", new { id = item.Id })'>
                            <button type="button" class="btn btn-danger">Borrar</button>
                        </a>
                    </td>
                </tr>
            }


        </table>
        @if (!Model.Any())
        {
            <div class="position-static alert alert-danger col-sm-6 mx-auto text-center" role="alert">
                Aun no hay nada en esta lista!
            </div>
        }
    </div>
}




