
@{
    ViewBag.Title = "Log";
}

<h2>Log</h2>



<table class="table">
    <tr>
        <th>
            Entradas
        </th>
        <th></th>
    </tr>

    @foreach (var item in ViewBag.Log)
    {
        <tr>
            <td>
                @item
            </td>
        </tr>
    }

</table>
