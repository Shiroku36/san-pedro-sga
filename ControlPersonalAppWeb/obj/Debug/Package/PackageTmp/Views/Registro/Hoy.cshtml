@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Registros del día";
    var tipo = "";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

<h2 class="display-4 text-center mb-2">Registros del día @DateTime.Now.ToLongDateString()</h2>

<div style="margin-top:24px">
    @Html.Partial("Busqueda")
</div>
@using (Html.BeginForm("Hoy", "Trabajador", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="col-sm-2 mb-3">
        <input type="submit" value="Descargar" class="btn btn-primary btn-block" />
    </div>

}
<div class="table-responsive">
    <table class="table table-hover" id="tabla">
        <tr class="bg-primary">
            <th>
                Nombre
            </th>
            <th>
                Tipo
            </th>
            <th>
                Hora
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Campo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Foto)
            </th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a href="/Registro/Index/@item.IdTrabajador"> @item.NombreTrabajador</a>
                </td>
                <td>
                    @if (item.Fecha.Hour < 12)
                    {
                        tipo = "Entrada";
                    }
                    else
                    {
                        tipo = "Salida";
                    }
                    @tipo
                </td>
                <td>
                    @item.Fecha.ToShortTimeString()
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Campo)
                </td>
                <td>
                    <img src="@String.Format("data:image/jpg;base64,{0}",System.Convert.ToBase64String(item.Foto))" width="110" />
                </td>
            </tr>
        }

    </table>
</div>
