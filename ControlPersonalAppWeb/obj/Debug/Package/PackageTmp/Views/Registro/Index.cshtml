@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Índice";
    var tipo = "";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

<h1 class="display-4 text-center">Registros - @ViewBag.Trabajador.Nombre @ViewBag.Trabajador.ApellidoPaterno @ViewBag.Trabajador.ApellidoMaterno</h1>

@if (cuenta.Permisos.Contains("RegistrosC"))
{
    <a href='@Url.Action("Create", "Registro",new { id = ViewBag.trabajador.Id })'>
        <label type="button" class="btn btn-primary float-right ml-2  mb-3">Crear Nuevo</label>
    </a>
}

<div class="clearfix"></div>

@using (Html.BeginForm())
{
    <br />
    <br />
    @Html.AntiForgeryToken()
<div class="table-responsive">
    <table class="table table-hover" id="tabla">
        <tr class="bg-primary">
            <th>
                @Html.DisplayNameFor(model => model.Fecha)
            </th>
            <th>
                Hora
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Campo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Foto)
            </th>
            <th></th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Fecha.ToShortDateString()
                </td>
                <td>
                    @item.Fecha.ToShortTimeString()
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Campo)
                </td>
                <td>
                    <img src="@String.Format("data:image/jpeg;base64,{0}", System.Convert.ToBase64String(item.Foto))" width="110" onclick="mostrarImagen(this)" style="cursor:pointer;" />
                </td>
                <td>
                    @if (cuenta.Permisos.Contains("RegistrosE"))
                    {
                        <a href='@Url.Action("Edit", "Registro", new { id = item.Id , idTrabajador = ViewBag.trabajador.Id})'>
                            <label title="Editar" type="submit" class="btn btn-warning">Editar</label>
                        </a>
                    }
                    <a href='@Url.Action("Details", "Registro", new { id = item.Id, idTrabajador = ViewBag.trabajador.Id })'>
                        <label title="Detalle" type="submit" class="btn btn-info">Detalle </label>
                    </a>
                    @if (cuenta.Permisos.Contains("RegistrosD"))
                    {
                        <a href='@Url.Action("Delete", "Registro", new { id = item.Id })'>
                            <label type="button" class="btn btn-danger" onclick="return confirm('¿Está seguro que desea eliminar el registro?');" })>Borrar</label>
                        </a>
                    }
                </td>
            </tr>
        }

    </table>
    <style>
        .modal {
            display: flex;
            justify-content: center;
            align-items: center;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            opacity: 0;
            transform: scale(0.8);
            transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
            pointer-events: none;
        }

            .modal.mostrar {
                opacity: 1;
                transform: scale(1);
                pointer-events: auto;
            }

        .modal-contenido {
            max-width: 80%;
            max-height: 80%;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
        }

        .cerrar {
            position: absolute;
            top: 15px;
            right: 35px;
            color: white;
            font-size: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

            .cerrar:hover {
                color: #ccc;
                transform: scale(1.1);
            }

    </style>
    <!-- Modal -->
    <div id="modalImagen" class="modal" onclick="cerrarImagen()">
        <span class="cerrar" onclick="cerrarImagen()">&times;</span>
        <img class="modal-contenido" id="imgAmpliada">
    </div>
</div>
}
<script>
    function mostrarImagen(img) {
        var modal = document.getElementById("modalImagen");
        var imgAmpliada = document.getElementById("imgAmpliada");
        imgAmpliada.src = img.src;
        modal.classList.add("mostrar");
    }

    function cerrarImagen() {
        var modal = document.getElementById("modalImagen");
        modal.classList.remove("mostrar");
    }
</script>
