                @Html.DropDownListFor(model => model.Banco, new SelectList(new string[] { "Estado", "BICE", "Santantder", "BCI", "Chile", "ITAU", "Falabella", "Scotiabank", "Security" }), htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.Banco, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <b class="control-label col-md-2">Número de cuenta</b>
