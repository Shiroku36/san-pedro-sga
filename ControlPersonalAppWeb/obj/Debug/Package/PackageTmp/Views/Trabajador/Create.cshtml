                                            "01. Banmédica",
                                            "02. Consalud",
                                            "03. VidaTres",
                                            "04. Colmena",
                                            "05. Isapre Cruz Blanca S.A.",
                                            "07. Fonasa",
                                            "09. Chuquicamata",
                                            "10. Nueva Masvida",
                                            "11. Institución de Salud Previsional Fusat Ltda.",
