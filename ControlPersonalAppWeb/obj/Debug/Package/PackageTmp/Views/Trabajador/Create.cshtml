                {
                    <input class="form-control" type="date" id="FechaNacimiento" value="" name="FechaNacimiento" min="1930-01-01">
                }
                else
                {
                    <input class="form-control" type="date" value="@Model.FechaNacimiento.Value.ToString("yyyy-MM-dd")" id="FechaNacimiento" name="FechaNacimiento" min="1930-01-01"
                           max="2002-01-01">
                }
            </div>
        </div>

        <div class="form-group">
            <b class="control-label col-md-2">Dirección</b>
