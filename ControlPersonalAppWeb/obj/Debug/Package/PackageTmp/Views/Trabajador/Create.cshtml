                <input class="form-control" maxlength="12" type="text" id="Rut" name="Rut" required onchange="cuenta();" placeholder="">
                <script src="~/Scripts/validarRUT.js"></script>
            </div>
        </div>

        <div class="form-group">
            <b class="control-label col-md-2">Tipo de cuenta</b>
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.TipoCuenta, new SelectList(new string[] { "Cuenta Rut", "Cuenta Vista", "Cuenta Corriente" }), htmlAttributes: new { @class = "form-control" })
