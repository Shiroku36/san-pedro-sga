        document.getElementById("Gratificacion").value = parseInt(document.getElementById("SueldoBase").value) * 0.25;
    }
    function cuenta() {
        var rut = document.getElementById("Rut").value;
        document.getElementById("NumeroCuenta").value = rut.substring(0, rut.length - 1);
    }


</script>

