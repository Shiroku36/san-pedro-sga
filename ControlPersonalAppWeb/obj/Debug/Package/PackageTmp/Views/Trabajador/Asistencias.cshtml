
@{
    ViewBag.Title = "Asistencias mensuales";
    var id = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada().Empresa;
}


    <h2 class="display-4 text-center my-3">Asistencias mensuales</h2>
<hr />
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="row" >

        <div class="col-sm-5">

            <div class="form-group ">
                <label class="control-label">Periodo</label>
                    <input class="form-control" type="month" name="Periodo" />
            </div>

            <div align="left" class="form-group">
                <div class="form-group">
                    <label class="control-label ">Hora</label>
                    <input class="form-control" maxlength="5" type="time" id="Hora" name="Hora" required value="08:00">
                </div>
            </div>


            <input type="hidden" value=@id name="id" id="id" />

            <div class="form-group">
                    <input type="submit" value="Generar" class="btn btn-primary btn-block" />
            </div>

        </div>

        

        <div class="col-sm-6">
            <h5 class="font-weight-normal mb-4 text-center">Trabajadores</h5>
            <div class="card overflow-auto mb-3" style="height:20rem">
                <!--<label><input type="checkbox" id="select_all" /> Seleccionar todos</label><br />-->
                <div class="card-body">
                    @foreach (var trabajador in ViewBag.Trabajador)
                    {
                        <label> <input type="checkbox" checked="checked" id="Permisos" name="centros" value=@trabajador.Id class="custom-checkbox chkCheckBoxId" /> @trabajador.Nombre @trabajador.ApellidoPaterno @trabajador.ApellidoMaterno - @trabajador.Rut</label> <br />
                    }
                </div>
            </div>

        </div>



    </div>
}
<script>
    $('#select_all').click(function () {
        var c = this.checked;
        $(':checkbox').prop('checked', c);
    });
</script>
