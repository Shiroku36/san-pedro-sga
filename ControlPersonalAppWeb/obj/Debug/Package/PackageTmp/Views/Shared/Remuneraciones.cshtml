@{
    ViewBag.Title = "Remuneración";
    int id = 0;
    if (ViewBag.trabajador != null)
    {
        id = ViewBag.trabajador.Id;
    }
}
<div>
    <ul class="nav bg-white">
        @if (ViewBag.Remuneracion == "HorasExtras")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "HorasExtras", new { id = id })'>Horas extras</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "HorasExtras", new { id = id })'>Horas extras</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "Finiquitos")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "Finiquitos", new { id = id })'> Finiquitos</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "Finiquitos", new { id = id })'> Finiquitos</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "HyDs")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "HyDs", new { id = id })'>HyD</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "HyDs", new { id = id })'>HyD</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "Licencias")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "Licencias", new { id = id })'>Licencias</a>
            </li>
        }
        else
        {
            <li class="nav-item ">
                <a class="nav-link" href='@Url.Action("Index", "Licencias", new { id = id })'>Licencias</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "Prestamos")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "Prestamos", new { id = id })'>Prestamos</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "Prestamos", new { id = id })'>Prestamos</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "Vacaciones")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "Vacaciones", new { id = id })'>Vacaciones</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "Vacaciones", new { id = id })'>Vacaciones</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "Remuneraciones")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Liquidacion", "Remuneraciones")'>Liquidaciones</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Liquidacion", "Remuneraciones")'>Liquidaciones</a>
            </li>
        }
        @if (ViewBag.Remuneracion == "AFPs")
        {
            <li class="nav-item active">
                <a class="nav-link" href='@Url.Action("Index", "AFPs")'>AFP</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" href='@Url.Action("Index", "AFPs")'>AFP</a>
            </li>
        }

    </ul>


    @if (ViewBag.Remuneracion != "Remuneraciones")
    {
        <div class="row mt-4 align-items-center">

            @if (string.IsNullOrEmpty(ViewBag.trabajador.Nombre))
            {
                <div class="alert alert-danger text-center col-md-4" role="alert">
                    Selecciona un trabajador
                </div>
            }
            else
            {
                <div class="alert alert-primary text-center col-md-4" role="alert">
                    <div class="row">
                        <div class="col-sm-6">
                            Nombre: <a href='@Url.Action("Details", "Trabajador", new { id = ViewBag.trabajador.Id })'>  @ViewBag.Trabajador.Nombre</a>
                        </div>
                        <div class="col-sm-6">
                            Rut: @ViewBag.Trabajador.Rut
                        </div>
                    </div>
                </div>
            }


            <div class="dropdown  col-sm-8">

                <div id="myDropdown" class="dropdown-content">

                    <div class="form-label-group ">
                        <input class="form-control py-2 border-right-0 border" type="text" placeholder="Busqueda trabajador" id="myInput" onkeyup="filterFunction()">
                        <div style="max-height:55vh" class="list-group position-absolute overflow-auto">
                            @foreach (var persona in ViewBag.personas)
                            {
                                <a class="list-group-item list-group-item-action" style="display:none" href='@Url.Action("index", ViewBag.Remuneracion, new { id = persona.Id })'>@persona.Nombre @persona.ApellidoPaterno @persona.ApellidoMaterno - @persona.Rut   </a>
                            }
                        </div>
                    </div>



                </div>


            </div>


        </div>
        <hr />

    }

    <script>
        function filterFunction() {
            var input, filter, a, i;
            input = document.getElementById("myInput");
            filter = input.value.toUpperCase();
            div = document.getElementById("myDropdown");
            a = div.getElementsByTagName("a");
            for (i = 0; i < a.length; i++) {
                if (filter.length > 0) {
                    txtValue = a[i].textContent || a[i].innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        a[i].style.display = "";
                    } else {
                        a[i].style.display = "none";
                    }
                }
                else {
                    a[i].style.display = "none";
                }
            }
        }
    </script>
</div>
