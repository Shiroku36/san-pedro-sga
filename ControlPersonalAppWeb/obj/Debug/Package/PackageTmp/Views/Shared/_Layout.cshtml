<!DOCTYPE html>
<html>
<head>
    @{
        string cuenta = "";
        if (ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada() != null)
        {
            if (ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada().Permisos != null)
            {
                cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada().Permisos;
            }
        }
        else if (ViewBag.Cuenta != "lala")
        {
            //<meta http-equiv="Refresh" content="0;url=http://sgajcp.ingenieriajcp.cl/Cuenta/Login" />
        }
    }
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - IngenieriaJCP</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink("SGA", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <!--<li>@Html.ActionLink("Acerca de", "About", "Home")</li>-->
                    @if (cuenta.Contains("HuertosV"))
                    {
                        <li>@Html.ActionLink("Huertos", "Index", "Campo")</li>
                    }
                    @if (cuenta.Contains("TrabajadoresV"))
                    {
                        <li>@Html.ActionLink("RR.HH.", "Index", "Trabajador")</li>
                    }
                    @if (cuenta.Contains("InformesV"))
                    {
                        <li>@Html.ActionLink("Informe", "Index", "Informes")</li>
                    }
                    @if (cuenta.Contains("Cosecha"))
                    {
                        <li>@Html.ActionLink("Modulo Cosecha", "Index", "Cosecha")</li>
                    }
                    @if (cuenta.Contains("EmpresasV"))
                    {
                        <li>@Html.ActionLink("Empresas", "Index", "Empresas")</li>
                    }
                    @if (cuenta.Contains("CuentasV"))
                    {
                        <li> @Html.ActionLink("Cuentas", "Index", "Cuenta") </li>
                    }
                    @if (cuenta.Contains("Remuneracion"))
                    {
                        <li>@Html.ActionLink("Remuneraciones", "Index", "HorasExtras")</li>
                    }
                    @if (ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada() != null)
                    {
                        if (ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada().Usuario.Contains("Shiroku"))
                        {
                            <li>@Html.ActionLink("Registros", "Registros", "Registro")</li>
                        }
                    }@if (cuenta.Contains("Log"))
                    {
                        <li>@Html.ActionLink("Log", "Log", "Home")</li>
                    }
                    <li>@Html.ActionLink("Contacto", "Contact", "Home")</li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    @Html.Partial("UserOption")
                </ul>
                <!-- BUSCAR!!! AQUIII -->
            </div>
        </div>
    </div>
    <div style="margin-left: 5%" class="container body-content col-lg-10">
        @if (ViewBag.Remuneracion != null)
        {
            @Html.Partial("Remuneraciones")
        }
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - IngenieriaJCP <img src="@Url.Content("~/Content/Jcp.JPG")" width="20" height="20" /></p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
