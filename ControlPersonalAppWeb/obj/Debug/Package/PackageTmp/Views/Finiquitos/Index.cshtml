@model IEnumerable<ControlPersonalAppWeb.Finiquito>

@{
    ViewBag.Title = "Índice";
}

<h2>Índice</h2>

@if (ViewBag.trabajador.Id != 0)
{
    <a href='@Url.Action("Create", "Finiquitos", new { id = ViewBag.trabajador.Id })'>
        <button type="button" class="btn btn-default">Crear nuevo</button>
    </a>
}
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Causa)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Texto)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaDocumento)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaFin)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.DiasDeVacaciones)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Dias)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.SueldoMensual)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.AvisoPrevio)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FactorAvisoPrevio)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Indemnización)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FactorIndemnizacion)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Vacaciones)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FactorVacaciones)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Total)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdTrabajador)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Causa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Texto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaDocumento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaFin)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DiasDeVacaciones)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Dias)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SueldoMensual)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AvisoPrevio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FactorAvisoPrevio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Indemnización)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FactorIndemnizacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vacaciones)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FactorVacaciones)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Total)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdTrabajador)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.Id })
            </td>
        </tr>
    }

</table>
