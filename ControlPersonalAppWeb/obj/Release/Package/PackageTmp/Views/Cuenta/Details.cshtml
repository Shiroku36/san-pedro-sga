@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Detalle";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}


<h2 class="display-4 text-center">Cuentas</h2>
<div>
    <h3 class="text-muted font-weight-light">Detalle</h3>
    <hr />
    <div class="col-sm-8 table-responsive">
        <table class="mx-auto table-borderless table-hover tabla-detalle">
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Usuario)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Usuario)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Nombre)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Nombre)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Apellido)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Apellido)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Email)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Email)
                </td>
            </tr>
        </table>
    </div>
    @if (cuenta.Id == Model.Id)
    {
    <div class="form-group col-md-9 mx-auto mt-5">
        @Html.ActionLink("Cambiar contraseña", "Password", new { id= cuenta.Id }, new { @class = "btn btn-block btn-info" })
    </div>
    }
    @if (cuenta.Permisos != null && cuenta.Permisos.Contains("CuentasV"))
    {
        <div class="form-group col-md-9 mx-auto mt-3">
            @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger" })
        </div>
    }
</div>