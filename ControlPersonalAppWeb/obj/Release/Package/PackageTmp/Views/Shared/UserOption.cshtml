@{
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

@if (cuenta != null)
{
    <div class="app-user">
        <a class="app-user__profile" href="@Url.Action("Details", "Cuenta", new { id = cuenta.Id })">
            <div class="app-user__identity">
            <span class="app-user__name">@cuenta.Usuario</span>
            <small class="app-user__company">@cuenta.Empresa</small>
            </div>
        </a>

        <div class="app-user__actions">
            @if (cuenta.Nivel == 6 && cuenta.TrabajadorId != null)
            {
                <a class="btn btn-outline-light btn-sm" href="@Url.Action("Index", "Registro", new { id = cuenta.TrabajadorId })">Registros</a>
            }
            <a class="btn btn-outline-light btn-sm" href="@Url.Action("Salir", "Cuenta")">Salir</a>
        </div>
    </div>
}
