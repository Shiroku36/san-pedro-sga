<!DOCTYPE html>
<html>
<head>
@{ 
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - IngenieriaJCP</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink("SGA", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav">
                    <!--<li>@Html.ActionLink("Acerca de", "About", "Home")</li>-->
                    @if (cuenta != null)
                    {
                        <li>@Html.ActionLink("Huertos", "Index", "Campo")</li>
                        <li>@Html.ActionLink("RR.HH.", "Index", "Trabajador")</li>
                        <li>@Html.ActionLink("Informes", "Index", "Informes")</li>
                        <li>@Html.ActionLink("Modulo Cosecha", "Index", "Cosecha")</li>
                        <li>@Html.ActionLink("ERP", "Index", "ERP")</li>
                        if (cuenta.Nivel == 1)
                        {
                            <li>@Html.ActionLink("Empresas", "Index", "Empresa")</li>
                            <li>@Html.ActionLink("Cuentas", "Index", "Cuenta")</li>
                        }
                    }
                    <li>@Html.ActionLink("Contacto", "Contact", "Home")</li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    @Html.Partial("UserOption")
                </ul>
                <!-- BUSCAR!!! AQUIII -->
            </div>
        </div>
    </div>
    <div  style="margin-left: 5%" class="container body-content col-lg-10">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - IngenieriaJCP <img src="@Url.Content("~/Content/Jcp.JPG")" width="20" height="20" /></p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
