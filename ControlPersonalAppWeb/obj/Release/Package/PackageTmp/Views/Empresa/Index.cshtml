@model IEnumerable<ControlPersonalAppWeb.Empresas>

@{
    ViewBag.Title = "Contratistas";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
    var totalContratistas = Model != null ? Model.Count() : 0;
    ViewData["SearchPlaceholder"] = "Buscar por contratista o RUT";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Contratistas</span>
        <h1>Contratistas</h1>
<p>@totalContratistas contratistas listos para revisar, actualizar y gestionar su personal.</p>
    </div>

    <div class="page-header__actions">
        @if (cuenta.Permisos.Contains("EmpresasC"))
        {
<a class="btn btn-primary" href="@Url.Action("Create", "Empresa")">Crear contratista</a>
        }
    </div>
</section>

<section class="surface">
    <div class="toolbar">
        <div>
            @Html.Partial("Busqueda")
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Rut)</th>
                    <th>@Html.DisplayNameFor(model => model.Nomina)</th>
                    <th class="data-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td>@Html.DisplayFor(modelItem => item.Rut)</td>
                        <td>@(!String.IsNullOrEmpty(item.Nomina) ? item.Nomina : "Sin archivo")</td>
                        <td>
                            <div class="table-actions">
                                @if (cuenta.Permisos.Contains("EmpresasE"))
                                {
                                    <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Empresa", new { id = item.Id })">Editar</a>
                                }
                                <a class="btn btn-sm btn-info" href="@Url.Action("Details", "Empresa", new { id = item.Id })">Detalle</a>
                                @if (cuenta.Permisos.Contains("EmpresasD"))
                                {
                                    <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", "Empresa", new { id = item.Id })" onclick="return confirm('¿Está seguro que desea eliminar el contratista?');">Eliminar</a>
                                }
                                <a class="btn btn-sm btn-success" href="@Url.Action("Habilitados", "Empresa", new { id = item.Id })">Habilitados</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
