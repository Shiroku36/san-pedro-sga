@using System.Linq
@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Registros";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
    var trabajador = ViewBag.trabajador;
    var totalRegistros = Model != null ? Model.Count() : 0;
    var workerId = ViewBag.idTrabajador ?? ViewBag.id;
    var nombreTrabajador = trabajador != null ? trabajador.Nombre + " " + trabajador.ApellidoPaterno + " " + trabajador.ApellidoMaterno : "Trabajador";
    ViewData["SearchPlaceholder"] = "Buscar por fecha, tipo o predio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Registros</span>
        <h1>Registros de @nombreTrabajador</h1>
        <p>@totalRegistros registros para revisar el historial y hacer correcciones si hace falta.</p>
    </div>

    <div class="page-header__actions">
        @if (cuenta.Permisos.Contains("RegistrosC"))
        {
            <a class="btn btn-primary" href="@Url.Action("Create", "Registro", new { id = workerId })">Nuevo registro</a>
        }
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Trabajador")">Volver a trabajadores</a>
    </div>
</section>

<section class="surface">
    <div class="toolbar">
        <div>
            @Html.Partial("Busqueda")
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Hora</th>
                    <th>@Html.DisplayNameFor(model => model.Campo)</th>
                    <th>Foto</th>
                    <th class="data-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        var tipo = item.Fecha.Hour < 12 ? "Entrada" : "Salida";
                        <tr>
                            <td>@item.Fecha.ToShortDateString()</td>
                            <td><span class="worker-status @(tipo == "Entrada" ? "worker-status--active" : "worker-status--inactive")">@tipo</span></td>
                            <td>@item.Fecha.ToShortTimeString()</td>
                            <td>@Html.DisplayFor(modelItem => item.Campo)</td>
                            <td>
                                @if (item.Foto != null)
                                {
                                    <img src="@String.Format("data:image/jpeg;base64,{0}", System.Convert.ToBase64String(item.Foto))" class="record-photo record-photo--clickable" alt="Registro de @nombreTrabajador" data-image-preview />
                                }
                                else
                                {
                                    <span class="record-photo record-photo--empty">Sin foto</span>
                                }
                            </td>
                            <td class="data-table__actions">
                                <div class="table-actions">
                                    @if (cuenta.Permisos.Contains("RegistrosE"))
                                    {
                                        <a class="btn btn-warning" href="@Url.Action("Edit", "Registro", new { id = item.Id, idTrabajador = workerId })">Editar</a>
                                    }
                                    <a class="btn btn-info" href="@Url.Action("Details", "Registro", new { id = item.Id, idTrabajador = workerId })">Detalle</a>
                                    @if (cuenta.Permisos.Contains("RegistrosD"))
                                    {
                                        <a class="btn btn-danger" href="@Url.Action("Delete", "Registro", new { id = item.Id })" onclick="return confirm('¿Está seguro que desea eliminar el registro?');">Borrar</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
