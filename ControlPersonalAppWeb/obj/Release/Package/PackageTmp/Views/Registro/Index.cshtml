@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Índice";
    var tipo = "";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

<h1 class="display-4 text-center">Registros - @ViewBag.Trabajador.Nombre @ViewBag.Trabajador.ApellidoPaterno @ViewBag.Trabajador.ApellidoMaterno</h1>

@if (cuenta.Permisos.Contains("RegistrosC"))
{
    <a href='@Url.Action("Create", "Registro",new { id = ViewBag.trabajador.Id })'>
        <label type="button" class="btn btn-primary float-right ml-2  mb-3">Crear Nuevo</label>
    </a>
}

<div class="clearfix"></div>

@using (Html.BeginForm())
{
    <br />
    <br />
    @Html.AntiForgeryToken()
    <div class="table-responsive">
        <table class="table table-hover" id="tabla">
            <tr class="bg-primary">
                <th>
                    @Html.DisplayNameFor(model => model.Fecha)
                </th>
                <th>
                    Hora
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Campo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Foto)
                </th>
                <th></th>
            </tr>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Fecha.ToShortDateString()
                    </td>
                    <td>
                        @item.Fecha.ToShortTimeString()
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Campo)
                    </td>
                    <td>
                        <img src="@String.Format("data:image/jgp;base64,{0}", System.Convert.ToBase64String(item.Foto))" width="110" />
                    </td>
                    <td>
                        @if (cuenta.Permisos.Contains("RegistrosE"))
                        {
                            <a href='@Url.Action("Edit", "Registro", new { id = item.Id , idTrabajador = ViewBag.trabajador.Id})'>
                                <label title="Editar" type="submit" class="btn btn-warning">Editar</label>
                            </a>
                        }
                        <a href='@Url.Action("Details", "Registro", new { id = item.Id, idTrabajador = ViewBag.trabajador.Id })'>
                            <label title="Detalle" type="submit" class="btn btn-info">Detalle </label>
                        </a>
                        @if (cuenta.Permisos.Contains("RegistrosD"))
                        {
                            <a href='@Url.Action("Delete", "Registro", new { id = item.Id })'>
                                <label type="button" class="btn btn-danger" onclick="return confirm('¿Está seguro que desea eliminar el registro?');" })>Borrar</label>
                            </a>
                        }
                    </td>
                </tr>
            }

        </table>
    </div>
}
