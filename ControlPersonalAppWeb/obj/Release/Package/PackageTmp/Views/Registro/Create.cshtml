@model ControlPersonalAppWeb.RegistroTrabajador

@{
    ViewBag.Title = "Crear";
}


@using (Html.BeginForm("Create", "Registro", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">

        <h4 class="text-center display-4">Registro trabajador</h4>
        <h3 class="text-muted font-weight-light">Crear</h3>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Uid, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input class="form-control" type="text" id="Uid" name="Uid" value=@ViewBag.Uid>
            @Html.ValidationMessageFor(model => model.Uid, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Fecha, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input class="form-control" type="datetime-local" id="Fecha" name="Fecha" min="2010-01-01" max="2030-01-01">
            @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Campo, htmlAttributes: new { @class = "control-label font-weight-normal" })
            @Html.DropDownListFor(model => model.Campo, new SelectList(ViewBag.Campos), htmlAttributes: new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.Campo, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.NombreTrabajador, htmlAttributes: new { @class = "control-label font-weight-normal" })
            @Html.EditorFor(model => model.NombreTrabajador, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.NombreTrabajador, "", new { @class = "text-danger" })
        </div>

        <input type="hidden" id="id" value=@ViewBag.id />

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Foto (opcional)</label>

            <div class=" my-1">
                <input id="Foto" type="file" name="Foto" accept="image/*" class="form-control">
            </div>

            @Html.ValidationMessageFor(model => model.Foto, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-9 mx-auto my-5">
            <input type="submit" value="Crear" class="btn btn-primary btn-block" />
            @Html.ActionLink("Volver a la lista", "Index", new { id = ViewBag.id }, new { @class = "btn btn-block btn-danger mt-3" })
        </div>

    </div>
}