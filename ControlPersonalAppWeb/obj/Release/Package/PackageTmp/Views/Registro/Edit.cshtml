@model ControlPersonalAppWeb.RegistroTrabajador

@{
    ViewBag.Title = "Editar registro";
    var workerId = ViewBag.idTrabajador;
    var workerName = ViewBag.WorkerName as string ?? Model.NombreTrabajador ?? "Trabajador";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Registros</span>
        <h1>Editar registro</h1>
        <p>Actualiza la información registrada para @workerName sin perder la asociación al trabajador.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Registro", new { id = workerId })">Volver a registros</a>
    </div>
</section>

@using (Html.BeginForm("Edit", "Registro", new { id = Model.Id }, FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)
    <input type="hidden" id="idTrabajador" name="idTrabajador" value="@workerId" />

    <section class="worker-create">
        <div class="worker-create__main">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Registro existente</span>
                    <h2>Datos editables</h2>
                    <p>Puedes ajustar fecha, predio, nombre visible y fotografia del registro.</p>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-4" })

                <div class="worker-form-grid">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Uid, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Uid, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Uid, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Fecha, htmlAttributes: new { @class = "toolbar__label" })
                        <input class="form-control" type="datetime-local" id="Fecha" name="Fecha" value="@Model.Fecha.ToString("yyyy-MM-ddTHH:mm")" min="2010-01-01T00:00" max="2030-01-01T00:00" />
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Campo, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.DropDownListFor(model => model.Campo, new SelectList(ViewBag.Campos, Model.Campo), htmlAttributes: new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.Campo, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.NombreTrabajador, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.NombreTrabajador, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.NombreTrabajador, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group worker-form-grid__wide">
                        <label class="toolbar__label" for="Foto">Foto</label>
                        @if (Model.Foto != null)
                        {
                            <div class="worker-photo-preview">
                                <img src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(Model.Foto))" alt="Registro actual de @workerName" class="record-photo--clickable" data-image-preview />
                            </div>
                        }
                        <input id="Foto" type="file" name="Foto" accept="image/*" class="form-control" />
                        @Html.ValidationMessageFor(model => model.Foto, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="worker-actions">
                    <input type="submit" value="Guardar cambios" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Registro", new { id = workerId })">Cancelar</a>
                </div>
            </section>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel worker-sidepanel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Contexto</span>
                    <h2>@workerName</h2>
                    <p>La edición mantiene el historial del trabajador y solo actualiza el registro seleccionado.</p>
                </div>
            </section>
        </aside>
    </section>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
