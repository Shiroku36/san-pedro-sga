@model ControlPersonalAppWeb.Campos

@{
    ViewBag.Title = "Editar predio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Predios</span>
        <h1>Editar predio</h1>
<p>Haz cambios en la ficha del predio sin perder el contexto de trabajo.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-primary" href="@Url.Action("Details", "Campo", new { id = Model.Id })">Ver detalle</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Campo")">Volver</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-4" })
    @Html.HiddenFor(model => model.Id)
    <input type="hidden" value="VSP" name="Empresa" />

    <div class="worker-create">
        <div class="worker-create__main">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Identidad</span>
                    <h2>Datos principales</h2>
<p>Actualiza el nombre, el lugar y los datos clave del predio.</p>
                </div>

                <div class="worker-form-grid">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Nombre, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Lugar, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Lugar, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Lugar, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group worker-form-grid__wide">
                        @Html.LabelFor(model => model.Coordenadas, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Coordenadas, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Coordenadas, "", new { @class = "text-danger" })
                    </div>
                </div>
            </section>

            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Responsables</span>
                    <h2>Equipo del predio</h2>
                    <p>Mantén al día responsables, asistentes y formas de contacto.</p>
                </div>

                <div class="worker-form-grid">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Encargado, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Encargado, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Encargado, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Asistente, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Asistente, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Asistente, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Correo, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Correo, new { htmlAttributes = new { @class = "form-control", type = "email" } })
                        @Html.ValidationMessageFor(model => model.Correo, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Telefono, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Telefono, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.TelefonoAsistente, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.TelefonoAsistente, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.TelefonoAsistente, "", new { @class = "text-danger" })
                    </div>
                </div>
            </section>

            <div class="worker-actions">
                <input type="submit" value="Guardar cambios" class="btn btn-primary" />
                <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Campo")">Cancelar</a>
            </div>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Referencia</span>
<h2>Resumen actual</h2>
                    <p>Usa este resumen para revisar rápido lo más importante antes de guardar.</p>
                </div>

                <div class="worker-detail-list">
                    <div class="worker-detail-list__row">
                        <span class="worker-detail-list__label">Predio</span>
                        <span class="worker-detail-list__value">@Model.Nombre</span>
                    </div>
                    <div class="worker-detail-list__row">
                        <span class="worker-detail-list__label">Lugar</span>
                        <span class="worker-detail-list__value">@Model.Lugar</span>
                    </div>
                    <div class="worker-detail-list__row">
                        <span class="worker-detail-list__label">Empresa</span>
                        <span class="worker-detail-list__value">@Model.Empresa</span>
                    </div>
                </div>
            </section>
        </aside>
    </div>
}
