@model ControlPersonalAppWeb.Trabajador

@{
    ViewBag.Title = "Detalle Trabajador";
}



    <h2 class="display-4 text-center">Trabajador</h2>
    <div>
        <h3 class="text-muted font-weight-light">Detalle</h3>
        <hr />
        <div class="col-sm-8 table-responsive">
            <table class="mx-auto table-borderless table-hover tabla-detalle">

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Nombre)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Nombre)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.ApellidoPaterno)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.ApellidoPaterno)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.ApellidoMaterno)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.ApellidoMaterno)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Rut)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Rut)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Numero)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Numero)
                    </td>
                </tr>

                <tr>
                    <td>
                        Contratista
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Empresa)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Email)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Email)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Direccion)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Direccion)
                    </td>
                </tr>

                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Sexo)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Sexo)
                    </td>
                </tr>


                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Telefono)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Telefono)
                    </td>
                </tr>


                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Habilitado)
                    </td>

                    @if (Model.Habilitado == true)
                    {
                        <td>
                            Si
                        </td>
                    }
                    else
                    {
                        <td>
                            No
                        </td>
                    }
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Nomina)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Nomina)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Contrato)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Contrato)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Anexo)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Anexo)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Odi)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Odi)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Registro_Epp)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Registro_Epp)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Registro_RIOHS)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Registro_RIOHS)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Registro_capacitación)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Registro_capacitación)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Examen_altura_física)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Examen_altura_física)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Procedimientos_de_trabajo)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Procedimientos_de_trabajo)
                    </td>
                </tr>
                <tr>
                    <td>
                        @Html.DisplayNameFor(model => model.Documento_Covid_19)
                    </td>

                    <td>
                        @Html.DisplayFor(model => model.Documento_Covid_19)
                    </td>
                </tr>



                <tr>
                    @if (Model.FotoCarnet != null)
                    {
                        <td>
                            @Html.DisplayNameFor(model => model.FotoCarnet)
                        </td>

                        <td>
                            <img src="@String.Format("data:image/jpg;base64,{0}",System.Convert.ToBase64String(Model.FotoCarnet))" width="400" />
                        </td>
                    }
                </tr>
                <tr>
                    @if (Model.Foto != null)
                    {
                        <td>
                            @Html.DisplayNameFor(model => model.Foto)
                        </td>

                        <td>
                            <img src="@String.Format("data:image/jpg;base64,{0}",System.Convert.ToBase64String(Model.Foto))" width="400"/>
                        </td>
                    }
                </tr>
            </table>
        </div>
        <div class="form-group col-md-9 mx-auto my-5">
            @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
        </div>
    </div>
