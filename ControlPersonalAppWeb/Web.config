  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- SMTP Configuration -->
    <add key="Smtp:Host" value="mail.ingenieriajcp.cl" />
    <add key="Smtp:Port" value="587" />
    <add key="Smtp:User" value="notificacionjcp@ingenieriajcp.cl" />
    <add key="Smtp:Password" value="notificacion" />
    <add key="Smtp:FromAddress" value="notificacionjcp@ingenieriajcp.cl" />
    <add key="Smtp:FromName" value="SGA JCP" />
    <add key="Smtp:EnableSsl" value="true" />
    <!-- File Storage -->
    <add key="FileStoragePath" value="C:\Data\Archivos\" />
  </appSettings>
  <!--
    Para obtener una descripción de los cambios de web.config, vea http://go.microsoft.com/fwlink/?LinkId=235367.

