@model IEnumerable<ControlPersonalAppWeb.ControlInventario>

@{
    ViewBag.Title = "Control Inventario";
}

<h2>Control Inventario</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>

@Html.Partial("Busqueda")
<table class="table" id="tabla">
    <tr class="bg-primary">
        <th>
            @Html.DisplayNameFor(model => model.Productos)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Razon)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Fecha)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Trabajador)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Productos)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Razon)
            </td>
            <td>
                @if (item.Fecha != null)
                {
                    <span>@item.Fecha.Value.ToShortDateString()</span>
                }
            </td>
            <td>
                <a href="/Trabajador/Detail/@item.TrabajadorId">
                    @Html.DisplayFor(modelItem => item.Trabajador)
                </a>
            </td>
            <td>
                @Html.ActionLink("Details", "Details", new { id = item.Id }) 
            </td>
        </tr>
    }

</table>

<script src="~/Scripts/Busqueda.js"></script>