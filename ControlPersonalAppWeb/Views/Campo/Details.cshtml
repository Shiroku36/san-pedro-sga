@model ControlPersonalAppWeb.Campos

@{
    ViewBag.Title = "Detalle";
}

    <h2 class="display-4 text-center">Huerto</h2>

<div>
    <h3 class="text-muted font-weight-light">Detalle</h3>
    <hr />
    <div class="col-sm-8 table-responsive">
        <table class="mx-auto table-borderless table-hover tabla-detalle">
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Nombre)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Nombre)
                </td>
            </tr>
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Lugar)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Lugar)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Empresa)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Empresa)
                </td>

            </tr>


            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Encargado)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Encargado)
                </td>


            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Correo)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Correo)
                </td>


            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Telefono)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Telefono)
                </td>


            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Asistente)
                </td>
                <td>
                    @Html.DisplayFor(model => model.Asistente)
                </td>


            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.TelefonoAsistente)
                </td>
                <td>
                    @Html.DisplayFor(model => model.TelefonoAsistente)
                </td>


            </tr>
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Coordenadas)
                </td>
                <td>
                    <iframe src="@Model.Coordenadas" width="1" height="1" frameborder="0" style="border:0" allowfullscreen></iframe>
                </td>
            </tr>

        </table>
    </div>
    <div class="form-group col-md-9 mx-auto my-5">
        @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
    </div>
</div>


