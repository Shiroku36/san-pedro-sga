@model ControlPersonalAppWeb.Campos

@{
    ViewBag.Title = "Detalle predio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Ficha Predio</span>
        <h1>@Model.Nombre</h1>
        <p>Consulta la información principal del predio en una sola vista.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-primary" href="@Url.Action("Edit", "Campo", new { id = Model.Id })">Editar predio</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Campo")">Volver</a>
    </div>
</section>

<div class="worker-detail-grid">
    <section class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Resumen</span>
            <h2>Datos principales</h2>
                    <p>Estos datos se usan todos los días en la operación y en varios filtros.</p>
        </div>

        <div class="worker-detail-list">
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Nombre</span>
                <span class="worker-detail-list__value">@Model.Nombre</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Lugar</span>
                <span class="worker-detail-list__value">@Model.Lugar</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Empresa</span>
                <span class="worker-detail-list__value">@Model.Empresa</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Coordenadas</span>
                <span class="worker-detail-list__value">@(!String.IsNullOrEmpty(Model.Coordenadas) ? Model.Coordenadas : "Sin coordenadas")</span>
            </div>
        </div>
    </section>

    <section class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Responsables</span>
            <h2>Contacto operativo</h2>
<p>Aqui quedan los nombres y contactos que mas se consultan.</p>
        </div>

        <div class="worker-detail-list">
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Encargado</span>
                <span class="worker-detail-list__value">@Model.Encargado</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Correo</span>
                <span class="worker-detail-list__value">@Model.Correo</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Telefono</span>
                <span class="worker-detail-list__value">@Model.Telefono</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Asistente</span>
                <span class="worker-detail-list__value">@(!String.IsNullOrEmpty(Model.Asistente) ? Model.Asistente : "Sin asistente")</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">Telefono asistente</span>
                <span class="worker-detail-list__value">@(!String.IsNullOrEmpty(Model.TelefonoAsistente) ? Model.TelefonoAsistente : "Sin telefono")</span>
            </div>
        </div>
    </section>
</div>
