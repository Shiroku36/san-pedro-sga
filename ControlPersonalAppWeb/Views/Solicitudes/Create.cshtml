@model ControlPersonalAppWeb.Solicitud

@{
    ViewBag.Title = "Crear Solicitud";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <h4 class="text-center display-4">Solicitud</h4>
    <h3 class="text-muted font-weight-light">Crear</h3>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })


<div class="col-md-8 mx-auto mb-3">
    <div class="card bg-warning">
        <label class="card-header text-center control-label">Ubicaciones</label>
        <div class="row card-body">
            <div class="form-group col-md-6 ">
                @Html.LabelFor(model => model.Origen, htmlAttributes: new { @class = "control-label" })
                @Html.DropDownListFor(model => model.Origen, new SelectList(ViewBag.campos), htmlAttributes: new { @class = "form-control", @onchange = "cargarHuertos(0)" })
                @Html.ValidationMessageFor(model => model.Origen, "", new { @class = "text-danger" })
            </div>
            <div class="form-group col-md-6">
                @Html.LabelFor(model => model.Destino, htmlAttributes: new { @class = "control-label" })
                @Html.DropDownListFor(model => model.Destino, new SelectList(ViewBag.campos), htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.Destino, "", new { @class = "text-danger" })
            </div>
        </div>
    </div>
    
    
</div>


    @Html.Partial("Productos")

<div>
    <div class="form-group col-md-8 mx-auto">
        @Html.LabelFor(model => model.Observación, htmlAttributes: new { @class = "control-label" }) 
        @Html.TextAreaFor(model => model.Observación, htmlAttributes: new { @class = "form-control w-100" } ) 
        @Html.ValidationMessageFor(model => model.Observación, "", new { @class = "text-danger" })
    </div>

    <div class="form-group col-md-9 mx-auto my-5">
        <input type="submit" value="Guardar" class="btn btn-primary btn-block" id="btnsubmit" />
        @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
    </div>
</div>
    
</div>
}
@Scripts.Render("~/bundles/jquery")
<script>
    var btn = $('#btnsubmit')
    var form = $('form')
    
    btn.on('click',function () {
        let origen = $('#Origen')
        let destino = $('#Destino')
        if (origen[0].options[origen[0].selectedIndex].value == destino[0].options[destino[0].selectedIndex].value) {
            destino[0].setCustomValidity('No puede ser igual al origen')
            return;
        } else {
            destino[0].setCustomValidity('')
        }
    })
    
</script>
