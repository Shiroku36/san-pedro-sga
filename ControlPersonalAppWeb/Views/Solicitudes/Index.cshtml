@model IEnumerable<ControlPersonalAppWeb.Solicitud>

@{
    ViewBag.Title = "Solicitudes";
}

<h2>Solicitudes</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<p>
    @Html.ActionLink("Aplicaciones de programa", "Index", "AplicacionDeProgramas")
</p>
@Html.Partial("Busqueda")
<table class="table" id="tabla">
    <tr class="bg-primary">
        <th>
            @Html.DisplayNameFor(model => model.Trabajador)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Productos)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Observación)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Origen)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Destino)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Estado)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Fecha)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                <a href="/Trabajador/Details/@item.TrabajadorId">
                    @Html.DisplayFor(modelItem => item.Trabajador)
                </a>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Productos)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Observación)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Origen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Destino)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Estado)
            </td>
            <td>
                @if (item.Fecha != null)
                {
                    <span>@item.Fecha.Value.ToShortDateString()</span>
                }
            </td>
            <td>
                @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                <a href="@Url.Action("Create", "AplicacionDeProgramas", new { id = item.Id })">Agregar aplicación</a> |
                <a href="@Url.Action("Index", "AplicacionDeProgramas", new { id = item.Id })">Ver aplicaciones</a>
            </td>
        </tr>
    }

</table>
