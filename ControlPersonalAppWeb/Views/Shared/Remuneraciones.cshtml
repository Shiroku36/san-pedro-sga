@{
    ViewBag.Title = "Remuneración";
    int id = 0;
    if(ViewBag.trabajador!=null)
    {
        id = ViewBag.trabajador.Id;
    }
}
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="~/Content/select2.min.css" rel="stylesheet" />
<script src="~/Scripts/select2.min.js"></script>
<style>
    body {
        font-family: Arial;
    }

    /* Style the tab */
    .tab {
        overflow: hidden;
        border: 1px solid #ccc;
        background-color: #f1f1f1;
    }

        /* Style the buttons inside the tab */
        .tab button {
            background-color: inherit;
            float: left;
            border: none;
            outline: none;
            cursor: pointer;
            padding: 14px 16px;
            transition: 0.3s;
            font-size: 17px;
        }

        /* Change background color of buttons on hover */
        .tab button:hover {
            background-color: #ddd;
        }

        /* Create an active/current tablink class */
        .tab button.active {
            background-color: #ccc;
        }
    /* Style the tab content */
    .tabcontent {
        display: none;
        padding: 6px 12px;
        border: 1px solid #ccc;
        border-top: none;
    }

    .dropbtn {
        background-color: #4CAF50;
        color: white;
        padding: 16px;
        font-size: 16px;
        border: none;
        cursor: pointer;
    }

        .dropbtn:hover, .dropbtn:focus {
            background-color: #3e8e41;
        }

    #myInput {
        font-size: 16px;
        padding: 14px 20px 12px 45px;
        border: none;
    }

        #myInput:focus {
            outline: 3px solid #ddd;
        }

    .dropdown {
        position: absolute;
        display: inline-block;
    }

    .dropdown-content {
        position: relative;
        background-color: #f6f6f6;
        min-width: 230px;
        overflow: auto;
        border: 1px solid #ddd;
        z-index: 1;
    }

        .dropdown-content a {
            position: relative;
            color: black;
            padding: 12px 16px;
            text-decoration: none;
            display: block;
        }

    .dropdown a:hover {
        background-color: #ddd;
    }

    .show {
        display: block;
    }
</style>
<div>
    <div class="tab form-group">

        @if (ViewBag.Remuneracion == "HorasExtras")
        {
            <a href='@Url.Action("Index", "HorasExtras", new { id = id })'><button id="HorasExtras" class="active">Horas extras</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "HorasExtras", new { id = id })'><button id="HorasExtras" class="tablinks">Horas extras</button></a>
        }
        @if (ViewBag.Remuneracion == "Finiquitos")
        {
            <a href='@Url.Action("Index", "Finiquitos", new { id = id })'><button id="Finiquitos" class="active">Finiquitos</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "Finiquitos", new { id = id })'> <button id="Finiquitos" class="tablinks">Finiquitos</button></a>
        }
        @if (ViewBag.Remuneracion == "HyDs")
        {
            <a href='@Url.Action("Index", "HyDs", new { id = id })'><button id="HyDs" class="active">HyD</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "HyDs", new { id = id })'><button id="HyDs" class="tablinks">HyD</button></a>
        }
        @if (ViewBag.Remuneracion == "Licencias")
        {
            <a href='@Url.Action("Index", "Licencias", new { id = id })'><button id="Licencias" class="active">Licencias</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "Licencias", new { id = id })'><button id="Licencias" class="tablinks">Licencias</button></a>
        }
        @if (ViewBag.Remuneracion == "Prestamos")
        {
            <a href='@Url.Action("Index", "Prestamos", new { id = id })'><button id="Prestamos" class="active">Prestamos</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "Prestamos", new { id = id })'><button id="Prestamos" class="tablinks">Prestamos</button></a>
        }
        @if (ViewBag.Remuneracion == "Vacaciones")
        {
            <a href='@Url.Action("Index", "Vacaciones", new { id = id })'><button id="Prestamos" class="active">Vacaciones</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "Vacaciones", new { id = id })'><button id="Prestamos" class="tablinks">Vacaciones</button></a>
        }
        @if (ViewBag.Remuneracion == "Remuneraciones")
        {
            <a href='@Url.Action("Liquidacion", "Remuneraciones")'><button id="Prestamos" class="active">Liquidaciones</button></a>
        }
        else
        {
            <a href='@Url.Action("Liquidacion", "Remuneraciones")'><button id="Prestamos" class="tablinks">Liquidaciones</button></a>
        }
        @if (ViewBag.Remuneracion == "AFPs")
        {
            <a href='@Url.Action("Index", "AFPs")'><button id="Prestamos" class="active">AFP</button></a>
        }
        else
        {
            <a href='@Url.Action("Index", "AFPs")'><button id="Prestamos" class="tablinks">AFP</button></a>
        }
    </div>
    @if (ViewBag.Remuneracion != "Remuneraciones")
    { 
        <div class="dropdown">
            <div id="myDropdown" class="dropdown-content">
                <input type="text" class="form-control" placeholder="Busqueda trabajador" id="myInput" onkeyup="filterFunction()">

                @foreach (var persona in ViewBag.personas)
                {
                    <a style="display:none" href='@Url.Action("index", ViewBag.Remuneracion, new { id = persona.Id })'>@persona.Nombre @persona.ApellidoPaterno @persona.ApellidoMaterno - @persona.Rut   </a>
                }
            </div>
        </div>
    <br />
    <hr />

    <div class="form-group">
        <p style="font-size:22px;" class="control-label">Trabajador:  <a href='@Url.Action("Details", "Trabajador", new { id = ViewBag.trabajador.Id })'>@ViewBag.Trabajador.Nombre  @ViewBag.Trabajador.Rut</a></p>
    </div>
    }
    <script>
        /* When the user clicks on the button,
        toggle between hiding and showing the dropdown content */
        function filterFunction() {
            var input, filter, ul, li, a, i;
            input = document.getElementById("myInput");
            filter = input.value.toUpperCase();
            div = document.getElementById("myDropdown");
            a = div.getElementsByTagName("a");
            for (i = 0; i < a.length; i++) {
                if (filter.length > 0) {
                    txtValue = a[i].textContent || a[i].innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        a[i].style.display = "";
                    } else {
                        a[i].style.display = "none";
                    }
                }
                else {
                    a[i].style.display = "none";
                }
            }
        }
    </script>
</div>
