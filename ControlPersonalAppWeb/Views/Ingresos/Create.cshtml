@model ControlPersonalAppWeb.Ingreso

@{
    ViewBag.Title = "Create";
}


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4 class="text-center display-4">Ingreso</h4>
        <h3 class="text-muted font-weight-light">Crear</h3>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        
   
    <div class="form-group col-sm-8 mx-auto ">
        <div class="card bg-warning ">
            <div class="card-header">@Html.LabelFor(model => model.Ubicacion, htmlAttributes: new { @class = "control-label" })</div>
            <div class="card-body">
                @Html.DropDownListFor(model => model.Ubicacion, new SelectList(ViewBag.campos), htmlAttributes: new { @class = "form-control", @onchange = "cargarHuertos()" })
                @Html.ValidationMessageFor(model => model.Ubicacion, "", new { @class = "text-danger" })
            </div>
            
        </div>
    </div>
        

        @Html.Partial("Productos")

        <div class="form-group col-sm-8 mx-auto">
            @Html.LabelFor(model => model.Proveedor, htmlAttributes: new { @class = "control-label " })
            @Html.DropDownListFor(model => model.Proveedor, new SelectList(ViewBag.empresas), htmlAttributes: new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(model => model.Proveedor, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-9 mx-auto my-5">
            <input type="submit" value="Guardar" class="btn btn-primary btn-block" id="btnsubmit" />
            @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
        </div>
    </div>
}