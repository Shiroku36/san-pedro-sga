@model IEnumerable<ControlPersonalAppWeb.Comentario>

@{
    ViewBag.Title = "Comentarios";
}
<h1 class="display-4 text-center">Comentarios</h1>
<hr />
<div style="margin-top:24px">
    @Html.Partial("Busqueda")
</div>
<div class="clearfix"></div>
<div class="table-responsive">
    <table class="table" id="tabla">
        <tr class="bg-primary">
            <th>
                @Html.DisplayNameFor(model => model.Trabajador)
            </th>
            <th>
                Ubicación
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Comentario1)
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a href='@Url.Action("Trabajador", "Historial", new { id = item.TrabajadorId })'>
                        @Html.DisplayFor(modelItem => item.Trabajador)
                    </a>
                </td>
                <td>
                    @if (item.AplicacionDeProgramaId != null)
                    {
                        <a href="/AplicacionDeProgramas/Details/@item.AplicacionDeProgramaId">
                            Ir a aplicación de programa
                        </a>
                    }
                    @if (item.SolicitudDeCompraId != null)
                    {
                        <a href="/SolicitudDeCompras/Details/@item.SolicitudDeCompraId">
                            Ir a solicitud de compra
                        </a>
                    }
                    @if (item.SolicitudId != null)
                    {
                        <a href="/Solicitudes/Details/@item.SolicitudId">
                            Ir a solicitud de producto
                        </a>
                    }
                    @if (item.IngresoId != null)
                    {
                        <a href="/Ingresos/Details/@item.IngresoId">
                            Ir a ingreso
                        </a>
                    }
                    @if (item.ControlInventarioId != null)
                    {
                        <a href="/ControlInventarios/Details/@item.ControlInventarioId">
                            Ir a gestión de insumos
                        </a>
                    }

                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Fecha)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Comentario1)
                </td>
            </tr>
        }

    </table>
    </div>
