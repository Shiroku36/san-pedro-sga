@model ControlPersonalAppWeb.Producto

@{
    ViewBag.Title = "Details";
}
<h4 class="text-center display-4">Productos</h4>
<h3 class="text-muted font-weight-light">Detalles</h3>
<hr />

<div>
    <div class="col-sm-8 table-responsive">
        <table class="mx-auto table-borderless table-hover tabla-detalle">
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Nombre)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Nombre)
                </td>

            </tr>
            
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Unidad)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Unidad)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Tipo)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Tipo)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.StockMin)
                </td>

                <td>
                    @Html.DisplayFor(model => model.StockMin)
                </td>
            </tr>
            
            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Descripcion)
                </td>

                <td>
                    @Html.DisplayFor(model => model.Descripcion)
                </td>
            </tr>

            <tr>
                <td>
                    @Html.DisplayNameFor(model => model.Foto)
                </td>

                <td>
                    @if (Model.Foto != null)
                    {
                        <img style="width:100%" src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(Model.Foto))" />
                    }
                </td>
            </tr>

            
        </table>
    </div>
</div>
<div class="form-group col-md-9 mx-auto my-5">
    @Html.ActionLink("Editar", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning btn-block " })
    @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
</div>
       
    
