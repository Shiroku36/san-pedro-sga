@model ControlPersonalAppWeb.Personas

@{
    ViewBag.Title = "Editar persona";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Personas</span>
        <h1>Editar persona</h1>
        <p>Actualiza la información de esta persona sin perder el contexto de la ficha.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Volver a Personas</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <section class="worker-create">
        <div class="worker-create__main">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Edición</span>
                    <h2>Actualizar datos</h2>
                    <p>Revisa y cambia solo lo necesario antes de guardar.</p>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-4" })

                <div class="worker-form-grid">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Rut, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Rut, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Rut, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Nombre, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.CentroCosto1, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.CentroCosto1, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.CentroCosto1, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.CentroCosto2, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.CentroCosto2, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.CentroCosto2, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.GlosaCosto, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.GlosaCosto, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.GlosaCosto, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.GlosaPuesto, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.GlosaPuesto, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.GlosaPuesto, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Ubicacion, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Ubicacion, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Ubicacion, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Instalacion, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Instalacion, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Instalacion, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="worker-actions">
                    <input type="submit" value="Guardar cambios" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Cancelar</a>
                </div>
            </section>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Referencia</span>
                    <h2>Antes de guardar</h2>
                    <p>Confirma que RUT, costo, ubicacion e instalacion sigan vigentes.</p>
                </div>
            </section>
        </aside>
    </section>
}
