@model IEnumerable<ControlPersonalAppWeb.Personas>

@{
    ViewBag.Title = "Personas";

    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

<h1 class="display-4 text-center">Índice personas</h1>
<hr />
<div class="row">
    <div class="col-sm-8 form-label-group">
        <input type="text" id="busqueda" onkeyup="buscar()" class="mb-3 mt-1 form-control" placeholder="Búsqueda">
    </div>
    <script src="~/Scripts/Busqueda.js"></script>
    <div class="form-group col-sm-4 mt-1">
        @if (cuenta.Permisos.Contains("PersonasC"))
        {
            <a href='@Url.Action("Create", "Personas")'>
                <label type="button" class="btn btn-primary float-right ml-2 mb-3">Crear Nuevo</label>
            </a>
        }

        <a href='@Url.Action("Cargar", "Personas")'>
            <label type="button" class="btn btn-primary float-right ml-2  mb-3">Cargar</label>
        </a>
    </div>
</div>
<body>
    <div class="table-responsive">
        <table class="table table-hover" id="tabla">
            <tr class="bg-primary">
                <th style="width:12%">
                    @Html.DisplayNameFor(model => model.Rut)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Nombre)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.GlosaCosto)
                </th>
                <th></th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Rut)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Nombre)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.GlosaCosto)
                    </td>
                    <td>
                        @if (cuenta.Permisos.Contains("PersonasE"))
                        {
                            <a href='@Url.Action("Edit", "Personas", new { id = item.Id })'>
                                <label title="Editar" type="button" class="btn btn-warning">Editar</label>
                            </a>
                        }

                        <a href='@Url.Action("Details", "Personas", new { id = item.Id })'>
                            <label title="Detalle" type="button" class="btn btn-info mx-1">Detalle</label>
                        </a>

                        @if (cuenta.Permisos.Contains("PersonasD"))
                        {
                            <a href='@Url.Action("Delete", "Personas", new { id = item.Id })' onclick="return confirm('¿Está seguro que desea eliminar a la persona?')">
                                <label title="Eliminar" type="button" class="btn btn-danger">Borrar</label>
                            </a>
                        }
                    </td>
                </tr>
            }

        </table>
    </div>
</body>
