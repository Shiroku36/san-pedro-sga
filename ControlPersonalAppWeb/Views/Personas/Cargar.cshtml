@{
    ViewBag.Title = "Cargar personas";
    var empresas = ViewBag.Empresas as IEnumerable<string>;
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Personas</span>
        <h1>Cargar personas</h1>
        <p>Importa o actualiza personas desde un archivo plano y refresca la base administrativa del módulo.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Volver a Personas</a>
    </div>
</section>

@using (Html.BeginForm("Cargar", "Personas", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <section class="worker-create">
        <div class="worker-create__main">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Importacion</span>
                    <h2>Documento fuente</h2>
                    <p>Selecciona el archivo de carga y procesa los registros disponibles para este entorno.</p>
                </div>

                <div class="form-group">
                    <label class="toolbar__label" for="csv">Documento</label>
                    <input id="csv" type="file" name="csv" class="form-control" />
                </div>

                @if (empresas != null)
                {
                    <div class="worker-panel__header mt-4">
                        <span class="worker-panel__eyebrow">Empresas visibles</span>
                        <h2>Alcance de la carga</h2>
                    </div>
                    <div class="import-company-list">
                        @foreach (var empresa in empresas)
                        {
                            <span class="import-company-list__item">@empresa</span>
                        }
                    </div>
                }

                <div class="worker-actions mt-4">
                    <input type="submit" value="Cargar archivo" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Cancelar</a>
                </div>
            </section>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Formato</span>
                    <h2>Columnas esperadas</h2>
                    <p>La carga considera centro de costo, ubicacion, instalacion, rut, nombre completo y glosa de puesto.</p>
                </div>
            </section>
        </aside>
    </section>
}
