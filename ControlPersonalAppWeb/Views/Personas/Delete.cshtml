@model ControlPersonalAppWeb.Personas

@{
    ViewBag.Title = "Eliminar persona";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Personas</span>
        <h1>Eliminar persona</h1>
        <p>Confirma la eliminacion del registro antes de retirarlo del listado.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Volver a Personas</a>
    </div>
</section>

<section class="worker-detail-grid">
    <article class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Confirmacion</span>
            <h2>Vas a eliminar este registro</h2>
            <p>Revisa los datos antes de confirmar esta accion.</p>
        </div>

        <div class="worker-detail-list">
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Rut)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Rut)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Nombre)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Nombre)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.GlosaCosto)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.GlosaCosto)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Ubicacion)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Ubicacion)</span>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="worker-actions mt-4">
                <input type="submit" value="Eliminar persona" class="btn btn-danger" />
                <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Personas")">Cancelar</a>
            </div>
        }
    </article>

    <article class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Contexto</span>
                    <h2>Información asociada</h2>
            <p>Este registro incluye referencia de costo, instalacion y puesto actual.</p>
        </div>

        <div class="worker-detail-list">
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.CentroCosto1)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.CentroCosto1)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.CentroCosto2)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.CentroCosto2)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.GlosaPuesto)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.GlosaPuesto)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Instalacion)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Instalacion)</span>
            </div>
        </div>
    </article>
</section>
