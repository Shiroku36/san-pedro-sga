@using System.Linq
@model dynamic

@{
    ViewBag.Title = "Asistencias mensuales";
    var id = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada().Empresa;
    var trabajadores = ViewBag.Trabajador as IEnumerable<ControlPersonalAppWeb.Models.TrabajadorIndex> ?? Enumerable.Empty<ControlPersonalAppWeb.Models.TrabajadorIndex>();
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Informes</span>
        <h1>Asistencias mensuales</h1>
        <p>Elige el mes y las personas incluidas para generar el comprobante de asistencia.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Informes")">Volver a Informes</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="hidden" value="@id" name="id" id="id" />

    <section class="surface surface--spacious">
        <div class="report-grid">
            <div class="report-stack">
                <article class="report-panel">
                    <div class="report-panel__header">
                        <span class="report-panel__eyebrow">Periodo</span>
                        <h2>Mes de referencia</h2>
                    <p>Selecciona el mes que quieres informar.</p>
                    </div>
                    <div class="report-panel__body">
                        <div class="form-group mb-0">
                            <label class="toolbar__label" for="Periodo">Periodo</label>
                            <input class="form-control" type="month" id="Periodo" name="Periodo" />
                        </div>
                    </div>
                </article>

                <article class="report-panel">
                    <div class="report-panel__header">
                    <span class="report-panel__eyebrow">Selección</span>
                        <h2>Inclusion masiva</h2>
                    <p>Marca o desmarca todo de una vez antes de ajustar la selección final.</p>
                    </div>
                    <div class="report-panel__body">
                        <label class="permission-check">
                            <input type="checkbox" onClick="toggle(this)" />
                            <span>Seleccionar todos</span>
                        </label>
                    </div>
                </article>
            </div>

            <div class="report-stack">
                <article class="report-panel report-panel--accent">
                    <div class="report-panel__header">
                        <span class="report-panel__eyebrow">Salida</span>
                        <h2>Generar documento</h2>
                        <p>Genera el documento con las personas seleccionadas y el mes indicado.</p>
                    </div>
                    <div class="report-panel__body">
                        <div class="report-actions">
                            <input type="submit" value="Generar asistencias" class="btn btn-success btn-block" />
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <section class="report-selection surface">
            <div class="worker-panel__header">
                <span class="worker-panel__eyebrow">Trabajadores</span>
                    <h2>Selección individual</h2>
                <p>Activa o desactiva personas puntuales antes de emitir el comprobante.</p>
            </div>

            @if (trabajadores.Any())
            {
                <div class="selection-grid">
                    @foreach (var trabajador in trabajadores)
                    {
                        <label class="permission-check selection-card">
                            <input type="checkbox" checked="checked" id="Permisos" name="centros" value="@trabajador.Id" class="chkCheckBoxId" />
                            <span>@trabajador.Nombre @trabajador.ApellidoPaterno @trabajador.ApellidoMaterno - @trabajador.Rut</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <div class="form-feedback form-feedback--info">
                    No hay trabajadores disponibles para generar este informe con la cuenta actual.
                    
                </div>
            }
        </section>
    </section>
}

<script>
    function toggle(source) {
        var checkboxes = document.getElementsByName('centros');
        for (var i = 0; i < checkboxes.length; i++) {
            checkboxes[i].checked = source.checked;
        }
    }
</script>
