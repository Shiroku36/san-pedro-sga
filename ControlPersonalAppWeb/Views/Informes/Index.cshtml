@{
    ViewBag.Title = "Informes";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

@using (Html.BeginForm())
{
    <section class="page-header">
        <div>
        <span class="page-header__eyebrow">Módulo Informes</span>
            <h1>Informes</h1>
            <p>Elige predio, contratista y fechas para bajar el informe que necesitas.</p>
        </div>

        <div class="page-header__actions">
            <a class="btn btn-outline-primary" href="@Url.Action("Horas", "Informes")">Horas extras</a>
            <a class="btn btn-outline-secondary" href="@Url.Action("Asistencias", "Informes")">Asistencias</a>
        </div>
    </section>

    @Html.AntiForgeryToken()

    <section class="surface surface--spacious">
        <div class="report-grid">
            <div class="report-stack">
                <article class="report-panel">
                    <div class="report-panel__header">
                        <span class="report-panel__eyebrow">Filtro principal</span>
                        <h2>Registros por predio</h2>
                    <p>Elige el predio del que quieres sacar la información.</p>
                    </div>
                    <div class="report-panel__body">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        <div class="form-group mb-0">
                            <label class="toolbar__label" for="Campo">Predio</label>
                            @Html.DropDownList("Campo", new SelectList(ViewBag.campos), htmlAttributes: new { @class = "form-control" })
                        </div>
                    </div>
                </article>

                @if (cuenta.Empresa == "VSP")
                {
                    <article class="report-panel">
                        <div class="report-panel__header">
                            <span class="report-panel__eyebrow">Filtro complementario</span>
                            <h2>Registros por contratista</h2>
                            <p>Si quieres, filtra por un contratista en particular.</p>
                        </div>
                        <div class="report-panel__body">
                            <div class="form-group mb-0">
                                <label class="toolbar__label" for="Empresa">Contratista</label>
                                @Html.DropDownList("Empresa", new SelectList(ViewBag.empresas), htmlAttributes: new { @class = "form-control" })
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="report-stack">
                <article class="report-panel">
                    <div class="report-panel__header">
                        <span class="report-panel__eyebrow">Periodo</span>
                        <h2>Rango de fechas</h2>
                        <p>Marca desde cuando y hasta cuando quieres revisar.</p>
                    </div>
                    <div class="report-panel__body report-panel__body--grid">
                        <div class="form-group mb-0">
                            <label class="toolbar__label" for="fecha_inicio">Inicio</label>
                            <input class="form-control" type="date" id="fecha_inicio" name="Inicio" min="2019-01-01" required />
                        </div>
                        <div class="form-group mb-0">
                            <label class="toolbar__label" for="fecha_fin">Fin</label>
                            <input class="form-control" type="date" id="fecha_fin" name="Fin" min="2019-01-01" required />
                        </div>
                    </div>
                </article>

                <article class="report-panel report-panel--accent">
                    <div class="report-panel__header">
                        <span class="report-panel__eyebrow">Salida</span>
                        <h2>Generar informe</h2>
                        <p>Elige el formato y descarga el informe al instante.</p>
                    </div>
                    <div class="report-panel__body">
                        <div class="report-format-group" role="radiogroup" aria-label="Formato de salida">
                            <label class="report-format-option">
                                <input type="radio" value="PDF" name="subject" checked="checked" />
                                <span>PDF</span>
                            </label>
                            <label class="report-format-option">
                                <input type="radio" value="EXCEL" name="subject" />
                                <span>Excel</span>
                            </label>
                        </div>
                        <input type="submit" value="Generar informe" class="btn btn-success btn-block mt-4" />
                    </div>
                </article>
            </div>
        </div>
    </section>
}

<script>
    function mostrar(enla) {
        obj = document.getElementById('oculto');
        obj.style.display = (obj.style.display == 'none') ? 'inline' : 'none';
    }
    function mostrar2(enla) {
        obj = document.getElementById('oculto2');
        obj.style.display = (obj.style.display == 'none') ? 'inline-block' : 'none';
    }
</script>
<script>
    $(document).ready(function () {
        const fechaInicioInput = $('#fecha_inicio');
        const fechaFinInput = $('#fecha_fin');

        fechaFinInput.change(function () {
            const fechaFin = new Date(this.value);
            const fechaInicio = new Date(fechaInicioInput.val());
            if (fechaFin < fechaInicio) {
                alert('La fecha de fin no puede ser menor que la fecha de inicio.');
                fechaFinInput.val(fechaInicioInput.val());
            }
        });
    });
</script>
