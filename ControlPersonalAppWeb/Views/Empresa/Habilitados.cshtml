@model IEnumerable<ControlPersonalAppWeb.Trabajador>

@{
    ViewBag.Title = "Habilitados";
    var totalTrabajadores = Model != null ? Model.Count() : 0;
    ViewData["SearchPlaceholder"] = "Buscar por nombre o RUT";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Contratistas</span>
        <h1>Habilitados</h1>
<p>@totalTrabajadores trabajadores de este contratista para activar o desactivar en un solo paso.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Empresa")">Volver a Contratistas</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="hidden" value="@ViewBag.id" name="IdEmpresa" id="IdEmpresa" />

    <section class="surface">
        <div class="toolbar">
            <div>
                @Html.Partial("Busqueda")
            </div>
            <div class="toolbar__actions toolbar__actions--emphasis">
<button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Rut)</th>
                    <th class="data-table__actions">
                            <label class="permission-check permission-check--select-all">
                                <input type="checkbox" onClick="toggle(this)" />
<span>Seleccionar todos</span>
                            </label>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre @item.ApellidoPaterno @item.ApellidoMaterno</td>
                            <td>@Html.DisplayFor(modelItem => item.Rut)</td>
                            <td class="data-table__actions">
                                <label class="permission-check permission-check--compact">
                                    <input type="checkbox" value="@item.Id" name="esta" id="esta" class="chkCheckBoxId" @(item.Habilitado == true ? "checked=\"checked\"" : null) />
                                    <span>@(item.Habilitado == true ? "Habilitado" : "Deshabilitado")</span>
                                </label>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<script>
    function toggle(source) {
        var checkboxes = document.getElementsByName('esta');
        for (var i = 0, n = checkboxes.length; i < n; i++) {
            checkboxes[i].checked = source.checked;
        }
    }
</script>
