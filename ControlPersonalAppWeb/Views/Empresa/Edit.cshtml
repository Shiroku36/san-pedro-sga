@model ControlPersonalAppWeb.Empresas

@{
    ViewBag.Title = "Editar";
}


@using (Html.BeginForm("Edit", "Empresa", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4 class="text-center display-4">Contratista</h4>
        <h3 class="text-muted font-weight-light">Editar</h3>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.Id)

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Nombre, htmlAttributes: new { @class = "control-label " })
            @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Rut, htmlAttributes: new { @class = "control-label " })
            @Html.EditorFor(model => model.Rut, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Rut, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <span>Nomina trabajadores</span><br />
            <span>@Model.Nomina</span>
            <input type="hidden" name="Nomina" value="@Model.Nomina" />
            <input type="file" name="Nomina1" class="form-control" />
        </div>
        <div class="form-group col-md-9 mx-auto my-5">
            <input type="submit" value="Guardar" class="btn btn-primary btn-block" />
            @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
