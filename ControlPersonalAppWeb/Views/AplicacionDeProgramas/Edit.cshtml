@model ControlPersonalAppWeb.AplicacionDePrograma

@{
    ViewBag.Title = "Editar Aplicacion de programa";
}


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    
<div class="form-horizontal">
    <h4 class="text-center display-4">Aplicacion del programa</h4>
    <h3 class="text-muted font-weight-light">Editar</h3>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.Id)

    <input type="hidden" name="SolicitudId" value="@Model.SolicitudId" />
    <div class="form-group col-md-8 mx-auto">
        @Html.LabelFor(model => model.Ubicacion, htmlAttributes: new { @class = "control-label font-weight-normal" })
        @Html.EditorFor(model => model.Ubicacion, new { htmlAttributes = new { @class = "form-control", required = "required" } })
        @Html.ValidationMessageFor(model => model.Ubicacion, "", new { @class = "text-danger" })
    </div>
    <div class="form-group col-md-8 mx-auto">
        @Html.LabelFor(model => model.FechaInicio, htmlAttributes: new { @class = "control-label " })
        <input class="form-control" type="date" value="@Model.FechaInicio.Value.ToString("yyyy-MM-dd")" id="FechaInicio" name="FechaInicio" min="2020-01-01" required>
        @Html.ValidationMessageFor(model => model.FechaInicio, "", new { @class = "text-danger" })
    </div>

    <div class="form-group col-md-8 mx-auto">
        @Html.LabelFor(model => model.FechaFin, htmlAttributes: new { @class = "control-label " })
        <input class="form-control" type="date" value="@Model.FechaFin.Value.ToString("yyyy-MM-dd")" id="FechaFin" name="FechaFin" min="2020-01-01" required>
        @Html.ValidationMessageFor(model => model.FechaFin, "", new { @class = "text-danger" })
    </div>
    <input type="hidden" name="SolicitudId" value="@Model.SolicitudId" />
    <div class="form-group col-md-9 mx-auto my-5">
        <input type="submit" value="Guardar" class="btn btn-primary btn-block" />
        @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
    </div>
</div>
}

