@model IEnumerable<ControlPersonalAppWeb.AplicacionDePrograma>

@{
    ViewBag.Title = "Aplicacion de Programa";
}

<h1 class="display-4 text-center">Aplicacion de Programa</h1>
<hr />

<div class="clearfix"></div>
<div class="table-responsive">
    <table class="table">
        <tr class="bg-primary">
            <th>
                <span>Solicitud</span>
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaInicio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaFin)
            </th>
            <th>
                Accion  
            </th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a href="/Solicitudes/Details/@item.SolicitudId">
                        @Html.DisplayFor(modelItem => item.SolicitudId)
                    </a>
                </td>
                <td>
                    <span>@item.FechaInicio.Value.ToShortDateString()</span>
                </td>
                <td>
                    <span>@item.FechaFin.Value.ToShortDateString()</span>
                </td>
                <td>
                    @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-warning" })
                    @Html.ActionLink("Detalles", "Details", new { id = item.Id }, new { @class = "btn btn-info" })
                </td>
            </tr>
        }

    </table>

</div>
