@{
    ViewBag.Title = "Nosotros";
}

<section class="public-section">
    <div class="public-section__hero">
        <span class="auth-kicker">Ingenieria JCP</span>
            <h1>Software, seguridad y gestión operativa con enfoque práctico.</h1>
        <p>Desarrollamos soluciones para control de personas, seguimiento operativo, sistemas de seguridad y proyectos de ingenieria aplicados a terreno.</p>
    </div>
</section>

<section class="public-section">
    <div class="public-info-grid">
