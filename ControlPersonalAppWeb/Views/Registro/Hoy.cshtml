@using System.Linq
@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Registros del día";
    var fechaVista = ViewBag.Fecha as string ?? DateTime.Now.ToString("dd-MM-yyyy");
    var totalRegistros = Model != null ? Model.Count() : 0;
    DateTime fechaParseada;
    var fechaInput = DateTime.TryParse(fechaVista, out fechaParseada) ? fechaParseada.ToString("yyyy-MM-dd") : DateTime.Now.ToString("yyyy-MM-dd");
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Registros</span>
        <h1>Registros del día</h1>
        <p>@totalRegistros registros encontrados para el día @fechaVista.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Home")">Volver al inicio</a>
    </div>
</section>

@using (Html.BeginForm("Hoy", "Registro", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <section class="surface">
        <div class="record-filter-grid record-filter-grid--wide">
            <div class="toolbar__search-wrap">
                <input type="text" placeholder="Buscar por nombre, campo o contratista" id="busqueda" onkeyup="buscar()" class="form-control toolbar__search search-input">
            </div>
            <div class="form-group mb-0">
                <label class="toolbar__label" for="Fecha">Fecha</label>
                <input type="date" class="form-control" id="Fecha" name="Fecha" value="@fechaInput" required />
            </div>
            <div class="record-filter-grid__action">
                <input type="submit" value="Actualizar fecha" class="btn btn-primary btn-block" />
            </div>
        </div>
    </section>
}

<section class="surface mt-4">
        <div class="worker-panel__header worker-panel__header--compact">
            <span class="worker-panel__eyebrow">Actividad</span>
            <h2>Registros cargados</h2>
                    <p>Consulta lo registrado durante el día y revisa la foto si existe.</p>
        </div>

    <div class="table-responsive">
        <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Nombre</th>
                    <th>Hora</th>
                    <th>@Html.DisplayNameFor(model => model.Campo)</th>
                    <th>Contratista</th>
                    <th>Foto</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd-MM-yyyy")</td>
                            <td>@item.NombreTrabajador</td>
                            <td>@item.Fecha.ToShortTimeString()</td>
                            <td>@Html.DisplayFor(modelItem => item.Campo)</td>
                            <td>@(string.IsNullOrEmpty(item.Empresa) ? "Desconocido" : item.Empresa)</td>
                            <td>
                                @if (item.Foto != null)
                                {
                                    <img src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(item.Foto))" class="record-photo record-photo--clickable" alt="Registro de @item.NombreTrabajador" data-image-preview />
                                }
                                else
                                {
                                    <span class="record-photo record-photo--empty">Sin foto</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
<script src="~/Scripts/Busqueda.js"></script>
