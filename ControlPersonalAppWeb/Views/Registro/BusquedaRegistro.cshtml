@using System.Linq
@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Busqueda de registros";
    var totalRegistros = Model != null ? Model.Count() : 0;
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Registros</span>
        <h1>Busqueda de registros</h1>
        <p>@totalRegistros resultados segun numero de pulsera o predio.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Home")">Volver al inicio</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <section class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Filtro</span>
            <h2>Consulta manual</h2>
            <p>Busca por numero de pulsera o predio y revisa el detalle de los registros encontrados.</p>
        </div>

        <div class="record-filter-grid record-filter-grid--wide">
            <div class="form-group mb-0">
                <label class="toolbar__label" for="Uid">Numero pulsera</label>
                <input class="form-control" type="text" id="Uid" placeholder="Buscar numero pulsera" name="Uid" />
            </div>
            <div class="form-group mb-0">
                <label class="toolbar__label" for="Campo">Predio</label>
                <select class="form-control" name="Campo" id="Campo">
                    @foreach (var campo in ViewBag.Campos)
                    {
                        <option value="@campo">@campo</option>
                    }
                </select>
            </div>
            <div class="record-filter-grid__action">
                <input type="submit" value="Buscar" class="btn btn-primary btn-block" />
            </div>
        </div>
    </section>
}

<section class="surface mt-4">
    <div class="table-responsive">
        <table class="table data-table table-hover">
            <thead>
                <tr>
                    <th>Referencia</th>
                    <th>@Html.DisplayNameFor(model => model.Uid)</th>
                    <th>@Html.DisplayNameFor(model => model.Fecha)</th>
                    <th>@Html.DisplayNameFor(model => model.Campo)</th>
                    <th>@Html.DisplayNameFor(model => model.Empresa)</th>
                    <th>@Html.DisplayNameFor(model => model.Foto)</th>
                    <th class="data-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NombreTrabajador</td>
                            <td>@Html.DisplayFor(modelItem => item.Uid)</td>
                            <td>@Html.DisplayFor(modelItem => item.Fecha)</td>
                            <td>@Html.DisplayFor(modelItem => item.Campo)</td>
                            <td>@Html.DisplayFor(modelItem => item.Empresa)</td>
                            <td>
                                @if (item.Foto != null)
                                {
                                    <img src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(item.Foto))" class="record-photo record-photo--clickable" alt="Registro @item.NombreTrabajador" data-image-preview />
                                }
                                else
                                {
                                    <span class="record-photo record-photo--empty">Sin foto</span>
                                }
                            </td>
                            <td class="data-table__actions">
                                <div class="table-actions">
                                    @if (item.IdTrabajador > 0)
                                    {
                                        <a class="btn btn-info" href="@Url.Action("Details", "Registro", new { id = item.Id, idTrabajador = item.IdTrabajador })">Detalle</a>
                                    }
                                    <a class="btn btn-danger" href="@Url.Action("Delete", "Registro", new { id = item.Id })" onclick="return confirm('¿Está seguro que desea eliminar el registro?');">Borrar</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
