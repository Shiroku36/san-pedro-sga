@using System.Linq
@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Registros por pulsera";
    var totalRegistros = Model != null ? Model.Count() : 0;
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Registros</span>
        <h1>Registros por pulsera</h1>
        <p>@totalRegistros registros asociados al numero consultado.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Home")">Volver al inicio</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <section class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Consulta</span>
            <h2>Numero de pulsera</h2>
            <p>Consulta el historial de registros asociado a una pulsera especifica.</p>
        </div>

        <div class="record-filter-grid record-filter-grid--wide">
            <div class="form-group mb-0">
                <label class="toolbar__label" for="numero">Numero</label>
                <input name="numero" id="numero" class="form-control" value="@ViewBag.numero" />
            </div>
            <div class="record-filter-grid__action">
                <button type="submit" class="btn btn-primary btn-block">Buscar</button>
            </div>
        </div>
    </section>

    <section class="surface mt-4">
        <div class="table-responsive">
            <table class="table data-table table-hover" id="tabla">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Fecha)</th>
                        <th>@Html.DisplayNameFor(model => model.Campo)</th>
                        <th>Foto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Fecha)</td>
                                <td>@Html.DisplayFor(modelItem => item.Campo)</td>
                                <td>
                                    @if (item.Foto != null)
                                    {
                                        <img src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(item.Foto))" class="record-photo record-photo--clickable" alt="Registro por pulsera" data-image-preview />
                                    }
                                    else
                                    {
                                        <span class="record-photo record-photo--empty">Sin foto</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
}
