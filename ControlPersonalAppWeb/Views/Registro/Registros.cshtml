@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Registros";
}

<h2>Registros @ViewBag.numero</h2>

<p>
    @Html.ActionLink("Crear nuevo", "Create")
</p>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input name="numero" class="form-control" />
    <button type="submit" class="form-control btn btn-primary mb-4 mt-4" >Buscar</button>
    <!--<button type="submit" value="Delete" class="btn btn-sm btn-danger rounded-0" onclick="return confirm('¿Está seguro que desea elminiar varios registros?')"><i class="fa fa-trash-o"></i> Delete</button>
    <br /><br />-->
    <table class="table table-hover" id="tabla">
        <tr class="bg-primary">
            <th>
                @Html.DisplayNameFor(model => model.Fecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Campo)
            </th>
            <th>
                Foto
            </th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <!--
                <td>
                    <input type="checkbox" id="ID" checked="checked" name="ID" value="@item.Id" class="custom-checkbox chkCheckBoxId" />
                </td>-->
                <td>
                    @Html.DisplayFor(modelItem => item.Fecha)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Campo)
                </td>
                <td>
                    <img src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(item.Foto))" width="110" />
                </td>
            </tr>
        }

    </table>
}
