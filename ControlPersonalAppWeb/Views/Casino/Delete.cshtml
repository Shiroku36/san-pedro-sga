@model ControlPersonalAppWeb.Casino

@{
    ViewBag.Title = "Eliminar servicio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Casino</span>
        <h1>Eliminar registro</h1>
        <p>Confirma si realmente quieres sacar este consumo del historial.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Casino")">Volver a Casino</a>
    </div>
</section>

<section class="worker-detail-grid">
    <article class="surface worker-panel casino-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Confirmacion</span>
            <h2>Vas a eliminar este registro</h2>
            <p>Revisa los datos antes de confirmar. Esta accion eliminara el registro y su foto asociada.</p>
        </div>

        <div class="worker-detail-list">
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Rut)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Rut)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Fecha)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Fecha)</span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Comida)</span>
                <span class="worker-detail-list__value"><span class="casino-service-pill">@Html.DisplayFor(model => model.Comida)</span></span>
            </div>
            <div class="worker-detail-list__row">
                <span class="worker-detail-list__label">@Html.DisplayNameFor(model => model.Ubicacion)</span>
                <span class="worker-detail-list__value">@Html.DisplayFor(model => model.Ubicacion)</span>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="worker-actions mt-4">
                <input type="submit" value="Eliminar registro" class="btn btn-danger" />
                <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Casino")">Cancelar</a>
            </div>
        }
    </article>

    <article class="surface worker-panel casino-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Evidencia</span>
            <h2>Foto asociada</h2>
        </div>

        @if (Model.Foto != null)
        {
            <div class="worker-photo-preview">
                <img src="@String.Format("data:image/jpeg;base64,{0}", System.Convert.ToBase64String(Model.Foto))" alt="Foto del servicio" class="record-photo--clickable" data-image-preview />
            </div>
        }
        else
        {
            <div class="form-feedback form-feedback--info">
                No hay fotografia asociada para este registro.
            </div>
        }
    </article>
</section>
