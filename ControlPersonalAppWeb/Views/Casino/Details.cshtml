@model ControlPersonalAppWeb.Casino


@{
    ViewBag.Title = "Crear";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}

<div>
    <h4>Casino</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.Rut)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Rut)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Fecha)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Fecha)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Comida)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Comida)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Foto)
        </dt>

        <dd>
            <img src="@String.Format("data:image/jpeg;base64,{0}", System.Convert.ToBase64String(Model.Foto))" width="300" onclick="mostrarImagen(this)" style="cursor:pointer;" />
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Ubicacion)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Ubicacion)
        </dd>

    </dl>
</div>

<style>
    .modal {
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
        opacity: 0;
        transform: scale(0.8);
        transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
        pointer-events: none;
    }

        .modal.mostrar {
            opacity: 1;
            transform: scale(1);
            pointer-events: auto;
        }

    .modal-contenido {
        max-width: 80%;
        max-height: 80%;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
    }

    .cerrar {
        position: absolute;
        top: 15px;
        right: 35px;
        color: white;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .cerrar:hover {
            color: #ccc;
            transform: scale(1.1);
        }
</style>
<!-- Modal -->
<div id="modalImagen" class="modal" onclick="cerrarImagen()">
    <span class="cerrar" onclick="cerrarImagen()">&times;</span>
    <img class="modal-contenido" id="imgAmpliada">
</div>
<script>
    function mostrarImagen(img) {
        var modal = document.getElementById("modalImagen");
        var imgAmpliada = document.getElementById("imgAmpliada");
        imgAmpliada.src = img.src;
        modal.classList.add("mostrar");
    }

    function cerrarImagen() {
        var modal = document.getElementById("modalImagen");
        modal.classList.remove("mostrar");
    }
</script>