@model ControlPersonalAppWeb.Casino

@{
    ViewBag.Title = "Editar servicio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Casino</span>
        <h1>Editar registro de servicio</h1>
        <p>Corrige los datos del consumo y actualiza su respaldo si hace falta.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Casino")">Volver a Casino</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <section class="worker-create">
        <div class="worker-create__main">
            <section class="surface worker-panel casino-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Edición</span>
                    <h2>Actualizar datos</h2>
                    <p>Modifica RUT, fecha, servicio, ubicacion y la imagen de este consumo.</p>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-4" })

                <div class="worker-form-grid">
                    <div class="form-group">
                        @Html.LabelFor(model => model.Rut, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Rut, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Rut, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Fecha, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Fecha, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Comida, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Comida, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Comida, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Ubicacion, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Ubicacion, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Ubicacion, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group worker-form-grid__wide">
                        @Html.LabelFor(model => model.Foto, htmlAttributes: new { @class = "toolbar__label" })
                        @Html.EditorFor(model => model.Foto, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Foto, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="worker-actions">
                    <input type="submit" value="Guardar cambios" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Casino")">Cancelar</a>
                </div>
            </section>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel casino-sidepanel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Referencia</span>
                    <h2>Antes de guardar</h2>
                    <p>Revisa que los cambios reflejen bien el consumo antes de guardarlos.</p>
                </div>
            </section>
        </aside>
    </section>
}
