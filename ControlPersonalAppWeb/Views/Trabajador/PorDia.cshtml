@model IEnumerable<ControlPersonalAppWeb.RegistroTrabajador>

@{
    ViewBag.Title = "Búsqueda por día";
    var totalRegistros = Model != null ? Model.Count() : 0;
    var tipo = "";
    int id = 0;
    string nombre = "";
    var inicioDefault = DateTime.Now.Date.AddHours(8).AddMinutes(15).ToString("yyyy-MM-ddTHH:mm");
    ViewData["SearchPlaceholder"] = "Buscar por nombre, tipo o predio";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo RR.HH.</span>
<h1>Registros por día</h1>
<p>@totalRegistros registros disponibles para revisar entradas y hacer seguimiento del día.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-primary" href="@Url.Action("Hoy", "Trabajador")">PDF del día</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Trabajador")">Volver a Trabajadores</a>
    </div>
</section>

@using (Html.BeginForm("PorDia", "Trabajador", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <section class="surface worker-panel">
        <div class="worker-panel__header">
            <span class="worker-panel__eyebrow">Filtro</span>
            <h2>Ventana de consulta</h2>
<p>Elige desde qué momento mirar y por cuántas horas quieres revisar registros.</p>
        </div>

        <div class="worker-form-grid">
            <div class="form-group">
                <label class="toolbar__label" for="Inicio">Inicio</label>
                <input id="Inicio" name="Inicio" type="datetime-local" class="form-control" value="@inicioDefault" />
            </div>

            <div class="form-group">
                <label class="toolbar__label" for="Horas">Horas a revisar</label>
                <select id="Horas" name="Horas" class="form-control">
                    <option value="4">4 horas</option>
                    <option value="8">8 horas</option>
                    <option value="12" selected="selected">12 horas</option>
                    <option value="24">24 horas</option>
                </select>
            </div>
        </div>

        <div class="worker-actions">
<input type="submit" value="Actualizar vista" class="btn btn-primary" />
            <a class="btn btn-outline-secondary" href="@Url.Action("PorDia", "Trabajador")">Restablecer</a>
        </div>
    </section>
}

<section class="surface mt-4">
    <div class="toolbar">
        <div>
            @Html.Partial("Busqueda")
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Hora</th>
                    <th>@Html.DisplayNameFor(model => model.Campo)</th>
                    <th>Foto</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        id = 0;
                        nombre = "Sin referencia";

                        foreach (var trabajador in ViewBag.trabajadores)
                        {
                            if (trabajador.Uid.Contains(item.Uid))
                            {
                                id = trabajador.Id;
                                nombre = trabajador.Nombre + " " + trabajador.ApellidoPaterno + " " + trabajador.ApellidoMaterno;
                            }
                        }

                        <tr>
                            <td>
                                @if (id > 0)
                                {
                                    <a class="record-link" href="@Url.Action("Index", "Registro", new { id = id })">@nombre</a>
                                }
                                else
                                {
                                    <span>@nombre</span>
                                }
                            </td>
                            <td>
                                @{
                                    tipo = item.Fecha.Hour < 12 ? "Entrada" : "Salida";
                                }
                                <span class="worker-status @(tipo == "Entrada" ? "worker-status--active" : "worker-status--inactive")">@tipo</span>
                            </td>
                            <td>@item.Fecha.ToShortTimeString()</td>
                            <td>@Html.DisplayFor(modelItem => item.Campo)</td>
                            <td>
                                @if (item.Foto != null)
                                {
                                    <img class="record-photo record-photo--clickable" src="@String.Format("data:image/jpg;base64,{0}", System.Convert.ToBase64String(item.Foto))" alt="Registro de @nombre" data-image-preview />
                                }
                                else
                                {
                                    <span class="record-photo record-photo--empty">Sin foto</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
