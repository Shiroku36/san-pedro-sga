@model ControlPersonalAppWeb.Trabajador

@{
    ViewBag.Title = "Crear";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}


@using (Html.BeginForm("Create", "Trabajador", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal" aling="center">
        <h4 class="text-center display-4">Trabajador</h4>
        <h3 class="text-muted font-weight-light">Crear</h3>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @if (!String.IsNullOrEmpty(ViewBag.texto))
        {
            <h2 align="center" style="color:red"><strong>@ViewBag.texto</strong></h2>
        }
        @if (String.IsNullOrEmpty(ViewBag.aviso))
        {
            <input type="hidden" name="aviso" id="aviso" />
        }
        else
        {
            <input type="hidden" name="aviso" value="Avisado" />
        }
        <h3 class="text-center font-weight-normal">Antecedentes</h3>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Nombre, htmlAttributes: new { @class = "control-label font-weight-normal" })
            *@Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Apellido Paterno</label>
            @Html.EditorFor(model => model.ApellidoPaterno, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.ApellidoPaterno, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Apellido Materno</label>
            @Html.EditorFor(model => model.ApellidoMaterno, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.ApellidoMaterno, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Rut, htmlAttributes: new { @class = "control-label font-weight-normal" })
            *
            @if (Model != null)
            {
                <input class="form-control" maxlength="12" type="text" id="Rut" value="@Model.Rut" oninput="return  this.setCustomValidity('')" name="Rut" placeholder="">
            }
            else
            {
                <input class="form-control" maxlength="12" type="text" id="Rut" name="Rut" oninput="return this.setCustomValidity('') " placeholder="">
            }
            <script src="~/Scripts/validarRUT.js"></script>
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Numero, htmlAttributes: new { @class = "control-label font-weight-normal" })
            @Html.EditorFor(model => model.Numero, new { htmlAttributes = new { @class = "form-control", type = "number" } })
            @Html.ValidationMessageFor(model => model.Numero, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "control-label font-weight-normal" })
            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", @type = "email" } })
            @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Dirección</label>

            @Html.EditorFor(model => model.Direccion, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Direccion, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Sexo, htmlAttributes: new { @class = "control-label font-weight-normal" })

            @Html.DropDownListFor(model => model.Sexo, new SelectList(new string[] { "Masculino", "Femenino" }), htmlAttributes: new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.Sexo, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Telefono, htmlAttributes: new { @class = "control-label font-weight-normal" })

            @Html.EditorFor(model => model.Telefono, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Contratista</label>
            <input list="Empresa" name="Empresa" class="form-control" required />
            <datalist id="Empresa">
                @foreach (var empresa in ViewBag.empresas)
                {
                    <option value="@empresa"></option>
                }
            </datalist>
            @Html.ValidationMessageFor(model => model.Empresa, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Habilitado, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="checkbox" class="form-control" id="Habilitado" name="Habilitado" value="true" />
            @Html.ValidationMessageFor(model => model.Habilitado, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Expiración, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="date" name="Expiración" id="Expiración" class="form-control" />
            @Html.ValidationMessageFor(model => model.Expiración, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Nomina, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Nomina" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Contrato, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Contrato" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Anexo, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Anexo" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Odi, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Odi" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Registro_Epp, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Registro_Epp" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Registro_RIOHS, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Registro_RIOHS" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Registro_capacitación, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Registro_capacitación" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Examen_altura_física, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Examen_altura_física" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Procedimientos_de_trabajo, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Procedimientos_de_trabajo" class="form-control" />
        </div>
        <div class="form-group col-md-8 mx-auto">
            @Html.LabelFor(model => model.Documento_Covid_19, htmlAttributes: new { @class = "control-label font-weight-normal" })
            <input type="file" name="Documento_Covid_19" class="form-control" />
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Foto Carnet</label>
            <div class=" my-1">
                <input id="FotoCarnet" type="file" name="FotoCarnet" accept="image/*" class="form-control">
            </div>
            @Html.ValidationMessageFor(model => model.FotoCarnet, "", new { @class = "text-danger" })
        </div>

        <div class="form-group col-md-8 mx-auto">
            <label class="control-label font-weight-normal">Foto perfil</label>
            <div class=" my-1">
                <input id="Foto" type="file" name="Foto" accept="image/*" class="form-control">
            </div>
            @Html.ValidationMessageFor(model => model.Foto, "", new { @class = "text-danger" })
        </div>
        <div class="form-group col-md-9 mx-auto mb-5">
            <input type="submit" value="Crear" class="btn btn-primary btn-block" />
            @Html.ActionLink("Volver a la lista", "Index", null, new { @class = "btn btn-block btn-danger mt-3" })
        </div>
    </div>
}


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

<script>
        $(document).ready(function () {
            let timeoutId;


            $('#Rut').on('change', function () {
                clearTimeout(timeoutId);
                const rut = $(this).val();
                document.getElementById("Rut").setCustomValidity('');

                timeoutId = setTimeout(function () {
                    checkRutAvailability(rut);
                }, 1000);
            });

            function checkRutAvailability(rut) {
                $.ajax({
                    url: '@Url.Action("CheckRut", "Trabajador")',
                    method: 'POST',
                    data: { rut: rut },
                    success: function (result) {
                        if (!result.isAvailable) {
                            document.getElementById("Rut").setCustomValidity('El Rut ingresado ya existe');
                        }
                        else {
                            document.getElementById("Rut").setCustomValidity('');

                        }
                    }
                });
            }


            $('#Numero').on('change', function () {
                clearTimeout(timeoutId);
                const numero = $(this).val();

                timeoutId = setTimeout(function () {
                    checkPulseraAvailability(numero);
                }, 1000);
            });

            function checkPulseraAvailability(numero) {
                $.ajax({
                    url: '@Url.Action("CheckPulsera", "Trabajador")',
                    method: 'POST',
                    data: { numero: numero },
                    success: function (result) {
                        if (!result.isAvailable) {
                            alert("Esta pulsera ya está asignada, si continúa se le cambiará")
                        }
                    }
                });
            }
        });
</script>