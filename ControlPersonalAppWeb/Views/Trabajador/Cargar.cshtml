@{
    ViewBag.Title = "Carga masiva";
    var empresas = ViewBag.Empresas as IEnumerable<string>;
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo RR.HH.</span>
        <h1>Carga masiva de trabajadores</h1>
<p>Importa trabajadores desde la plantilla oficial para registrar ingresos de forma rápida y ordenada.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-primary" href="@Url.Action("DescargarArchivo", "Trabajador")">Descargar plantilla</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Trabajador")">Volver a Trabajadores</a>
    </div>
</section>

@using (Html.BeginForm("Cargar", "Trabajador", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <section class="worker-create worker-create--wide">
        <div class="worker-create__main">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Archivo</span>
                    <h2>Subir documento de carga</h2>
<p>Usa la plantilla base y mantén su estructura para que la carga funcione sin problemas.</p>
                </div>

                @if (ViewBag.mensaje != null)
                {
                    if (ViewBag.mensaje)
                    {
                        <div class="form-feedback form-feedback--success">
                            Archivo cargado correctamente.
                        </div>
                    }
                    else
                    {
                        <div class="form-feedback form-feedback--error">
                            Error al cargar el archivo. Revisa el formato de la plantilla e intenta nuevamente.
                        </div>
                    }
                }

                <div class="worker-form-grid">
                    <div class="form-group worker-form-grid__wide">
                        <label class="toolbar__label" for="csv">Documento</label>
                        <input id="csv" type="file" name="csv" class="form-control" value="@ViewBag.documento" />
                    </div>
                </div>

                <div class="worker-actions">
                    <input type="submit" value="Cargar trabajadores" class="btn btn-primary" />
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Trabajador")">Cancelar</a>
                </div>
            </section>
        </div>

        <aside class="worker-create__aside">
            <section class="surface worker-panel">
                <div class="worker-panel__header">
                    <span class="worker-panel__eyebrow">Antes de importar</span>
                    <h2>Recomendaciones</h2>
<p>Una carga limpia evita duplicados y te ahorra correcciones después.</p>
                </div>

                <ul class="entity-note-list">
                        <li>Descarga la plantilla desde este mismo módulo para mantener el orden de columnas esperado.</li>
                    <li>Verifica RUT, numero de pulsera y contratista antes de subir el archivo.</li>
                    <li>Si la cuenta no es administradora, la lista quedara limitada a su propio contratista.</li>
                </ul>
            </section>

            @if (empresas != null && empresas.Any())
            {
                <section class="surface worker-panel">
                    <div class="worker-panel__header">
                        <span class="worker-panel__eyebrow">Contexto</span>
                        <h2>Empresas disponibles</h2>
<p>La carga se valida con las empresas que tu cuenta puede ver.</p>
                    </div>

                    <div class="import-company-list">
                        @foreach (var empresa in empresas)
                        {
                            <span class="import-company-list__item">@empresa</span>
                        }
                    </div>
                </section>
            }
        </aside>
    </section>
}
