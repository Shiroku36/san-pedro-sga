@model IEnumerable<ControlPersonalAppWeb.Models.TrabajadorIndex>

@{
    ViewBag.Title = "RR.HH.";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}
@if (!String.IsNullOrEmpty(ControlPersonalAppWeb.Utils.SessionManager.mensaje))
{
    <div class="alert-info">
        <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
        @ControlPersonalAppWeb.Utils.SessionManager.mensaje
    </div>
    ControlPersonalAppWeb.Utils.SessionManager.mensaje = "";
}
<h1 class="display-4 text-center">Índice RR.HH.</h1>
<hr />

<div class="clearfix"></div>
<div class="row">
    <div class="col-sm-8 form-label-group">
        <input type="text" id="busqueda" onkeyup="buscar()" class="mb-3 mt-1 form-control" placeholder="Búsqueda">
    </div>
    <div class="form-group col-sm-4 mt-1">
        @if (cuenta.Permisos.Contains("TrabajadoresC"))
        {
            <a href='@Url.Action("Create", "Trabajador")'>
                <label type="button" class="btn btn-primary float-right ml-2  mb-3">Crear Nuevo</label>
            </a>
        }
        @if (cuenta.Permisos.Contains("TrabajadoresU"))
        {
            <a href='@Url.Action("Cargar", "Trabajador")'>
                <label type="button" class="btn btn-primary float-right ml-2  mb-3">Cargar</label>
            </a>
        }
        <a href='@Url.Action("Hoy", "Registro")'>
            <label type="button" class="btn btn-primary float-right  ">Registros del día</label>
        </a>
        <!--
    <a href='@Url.Action("Borrar", "Trabajador")'>
        <button type="button" class="btn btn-default">borrar</button>
    </a>-->
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" id="tabla">
        <tr class="bg-primary">
            <th style="width:12%">
                @Html.DisplayNameFor(model => model.Rut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                Contratista
            </th>
            <th>
                Numero pulsera
            </th>
            <th style="width:40%">
                Acción
            </th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.Rut
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ApellidoPaterno) @Html.DisplayFor(modelItem => item.ApellidoMaterno) @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Empresa)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Numero)
                </td>

                <td>
                    @if (cuenta.Permisos.Contains("RegistrosV"))
                    {
                        <a href='@Url.Action("Index", "Registro", new { id = item.Id })'>
                            <label type="button" class="btn btn-dark">Registros</label>
                        </a>
                    }

                    @if (cuenta.Permisos.Contains("TrabajadoresE"))
                    {
                        <a href='@Url.Action("Edit", "Trabajador", new { id = item.Id })'>
                            <label title="Editar" type="submit" class="btn btn-warning">Editar</label>
                        </a>
                    }
                    <a href='@Url.Action("Details", "Trabajador", new { id = item.Id })'>
                        <label title="Detalle" type="submit" class="btn btn-info">Detalle </label>
                    </a>
                    @if (cuenta.Permisos.Contains("TrabajadoresD"))
                    {
                        <a href='@Url.Action("Delete", "Trabajador", new { id = item.Id })' onclick="return confirm('¿Está seguro que desea eliminar el Trabajador?')" })>
                            <label title="Eliminar" type="submit" class="btn btn-danger">Borrar</label>
                        </a>
                    }

                </td>

            </tr>
        }
    </table>
</div>

<script src="~/Scripts/Busqueda.js"></script>
