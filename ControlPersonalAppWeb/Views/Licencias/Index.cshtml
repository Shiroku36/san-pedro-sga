@model IEnumerable<ControlPersonalAppWeb.Licencia>

@{
    ViewBag.Title = "Índice";
}

@if (ViewBag.trabajador.Id != 0)
{
    <a href='@Url.Action("Create", "Licencias", new { id = ViewBag.trabajador.Id })'>
        <button type="button" class="btn btn-default">Crear nuevo</button>
    </a>
}
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Desde)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Dias)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Hasta)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Causa)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
    <tr>

        <td>
            @item.Desde.Value.ToString("dd-MM-yyyy")
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Dias)
        </td>
        <td>
            @item.Hasta.Value.ToString("dd-MM-yyyy")
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Causa)
        </td>
        <td>
            <a href='@Url.Action("Edit", "Licencias", new { id = item.Id })'>
                <button type="button" class="btn btn-default">Editar</button>
            </a>
            <a href='@Url.Action("Details", "Licencias", new { id = item.Id })'>
                <button type="button" class="btn btn-default">Detalle</button>
            </a>
            <a href='@Url.Action("Delete", "Licencias", new { id = item.Id })'>
                <button type="button" class="btn btn-default" })>Borrar</button>
            </a>
        </td>
    </tr>
    }

</table>
