@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Acceso";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var intentoFallido = Request.HttpMethod == "POST";
}

<section class="auth-shell">
    <div class="auth-shell__intro">
        <span class="auth-kicker">Acceso interno</span>
        <h1>Tu operación, más clara y más ordenada.</h1>
        <p>Entra al sistema para revisar personas, registros y operación diaria desde una sola vista.</p>

        <ul class="auth-points">
            <li>RR.HH. y fichas de trabajadores</li>
            <li>Registros, asistencia e informes</li>
            <li>Solicitudes, inventario y control interno</li>
        </ul>
    </div>

    <div class="auth-card">
        <div class="auth-card__brand">
            <img src="@Url.Content("~/Images/Logo.png")" alt="SGA" />
            <div>
                <strong>SGA</strong>
                        <small>San Pedro Gestión Agrícola</small>
            </div>
        </div>

        <h2>Entrar</h2>
        <p class="auth-card__copy">Usa tu cuenta para acceder a tu espacio de trabajo.</p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            if (intentoFallido)
            {
                <div class="form-feedback form-feedback--error">
                    No pudimos iniciar sesión con esos datos.
                </div>
            }

            <div class="auth-form">
                <div class="form-group">
                    <label for="Usuario">Usuario</label>
                    @Html.TextBoxFor(model => model.Usuario, new { @class = "form-control", @placeholder = "Escribe tu usuario" })
                    @Html.ValidationMessageFor(model => model.Usuario, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label for="Password">Contraseña</label>
                    <input class="form-control" type="password" id="Password" name="Password" placeholder="Escribe tu contraseña" />
                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-primary btn-block auth-submit">Entrar</button>
            </div>
        }
    </div>
</section>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
