@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Login";
    //Layout = null;
}

<style>
    .error-message {
        background-color: pink;
        color: black;
        padding: 20px;
        border: 2px solid red;
        border-radius: 10px;
        width: fit-content;
        margin: 20px 0;
        text-align: center;
        align-items: center;
    }
</style>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="row bg-light mt-3">
        <div class="col-sm-9 col-md-7 col-lg-5 mx-auto">
            <div class="card card-signin my-5">
                <div class="card-body">
                    <h3 class="card-title text-center ">Iniciar sesion</h3>
                    <div class="form-signin">
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        <div class="form-label-group">
                            @* @Html.LabelFor(model => model.Usuario, htmlAttributes: new { @class = "control-label " }) *@
                            <div class="col-sm-10 mx-auto">
                                @Html.EditorFor(model => model.Usuario, new { htmlAttributes = new { @class = "form-control", @placeholder = "Usuario" } })
                                @Html.ValidationMessageFor(model => model.Usuario, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-label-group col-sm-10 mx-auto">
                            @* @Html.LabelFor(model => model.Password, htmlAttributes: new { @class = "control-label" }) *@
                            <input class="form-control " type="password" id="Password" name="Password" placeholder="Contraseña">
                            @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                        </div>
                        <div>
                            <button type="submit" value="Login" class="btn btn-lg btn-block btn-primary text-uppercase mt-4">Entrar</button>
                        </div>
                        @if (ViewBag.error != null)
                        {
                            <div>
                                <p class="error-message">@ViewBag.error</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
