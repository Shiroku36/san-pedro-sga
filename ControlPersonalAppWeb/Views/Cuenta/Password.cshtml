@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Cambiar contraseña";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Seguridad de cuenta</span>
        <h1>Cambiar contraseña</h1>
<p>Cambia la clave de acceso del usuario confirmando primero la contraseña actual.</p>
    </div>

    <div class="page-header__actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Details", "Cuenta", new { id = Model.Id })">Volver al perfil</a>
    </div>
</section>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)

    <div class="worker-detail-grid">
        <section class="surface worker-panel">
            <div class="worker-panel__header">
                <span class="worker-panel__eyebrow">Validación</span>
                <h2>Datos de seguridad</h2>
<p>Confirma la contraseña actual antes de guardar la nueva.</p>
            </div>

            @if (ViewBag.alerta == 2)
            {
                <div class="form-feedback form-feedback--error">
                    La contraseña actual no es correcta.
                </div>
            }

            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-4" })

            <div class="worker-form-grid">
                <div class="form-group">
                    <label class="toolbar__label" for="Contraseña">Contraseña actual</label>
                    <input class="form-control" type="password" id="Contraseña" name="Contraseña" required />
                </div>

                <div class="form-group">
                    <label class="toolbar__label" for="Password">Nueva contraseña</label>
                    <input class="form-control" type="password" id="Password" name="Password" required />
                </div>

                <div class="form-group">
                    <label class="toolbar__label" for="Confirmar">Confirmar contraseña</label>
                    <input class="form-control" type="password" id="Confirmar" required />
                </div>
            </div>

            <div class="worker-actions">
<input type="submit" value="Guardar contraseña" class="btn btn-primary" />
                <a class="btn btn-outline-secondary" href="@Url.Action("Details", "Cuenta", new { id = Model.Id })">Cancelar</a>
            </div>
        </section>

        <section class="surface worker-panel">
            <div class="worker-panel__header">
                <span class="worker-panel__eyebrow">Referencia</span>
<h2>Recomendación</h2>
<p>Asegúrate de confirmar bien la nueva contraseña antes de guardar.</p>
            </div>

            <ul class="entity-note-list">
                <li>La validación compara la clave nueva con el campo de confirmación antes de enviar.</li>
                <li>Si la contraseña actual es incorrecta, el formulario vuelve con advertencia sin aplicar cambios.</li>
            </ul>
        </section>
    </div>
}

@Scripts.Render("~/bundles/jquery")
<script>
    let pwd = $('#Password');
    let pwdConfirm = $('#Confirmar');
    $("form").submit(function (e) {
        if (pwd[0].value != pwdConfirm[0].value) {
            pwdConfirm[0].setCustomValidity("Contraseñas no coinciden");
            e.preventDefault();
            return;
        }
        pwdConfirm[0].setCustomValidity("");
    });
</script>
