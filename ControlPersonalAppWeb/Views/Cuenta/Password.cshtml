@model ControlPersonalAppWeb.Cuentas

@{
    ViewBag.Title = "Editar contraseña";
    var autenticada = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
}


    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4 class="text-center display-4">Contraseña</h4>
        <h3 class="text-muted font-weight-light">Editar</h3>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.Id)

    <div class="row" style="text-align: center;">
        <div class="col-sm-10 mx-auto">
            @if (ViewBag.alerta == 2)
            {
                <div class="my-3 mx-auto alert alert-warning" role="alert">
                    Contraseña actual no es correcta
                </div>
            }
        </div>
        <div class="col-sm-12">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group col-sm-6 mx-auto">
                <label>Contraseña actual</label>
                <input class="form-control" type="password" id="Contraseña" name="Contraseña" required />
            </div>

            <div class="form-group col-sm-6 mx-auto">
                <label>Nueva contraseña</label>
                <input class="form-control" type="password" id="Password" name="Password" required />
            </div>

            <div class="form-group col-sm-6 mx-auto">
                <label>Confirmar contraseña</label>
                <input class="form-control" type="password" id="Confirmar" required />
            </div>

        </div>
    </div>

        <div class="form-group col-md-9 mx-auto my-5">
            <input type="submit" value="Guardar" class="btn btn-primary btn-block"/>
            @Html.ActionLink("Volver", "Details", new { Model.Id}, new { @class = "btn btn-block btn-danger mt-3" })
        </div>
    </div>
    }


@Scripts.Render("~/bundles/jquery")
<script>
    let pwd = $('#Password')
    let pwdConfirm = $('#Confirmar')
    $("form").submit(function (e) {
        if (pwd[0].value != pwdConfirm[0].value) {
            pwdConfirm[0].setCustomValidity("Contraseñas no coinciden")
            e.preventDefault()
            return;
        }
        pwdConfirm[0].setCustomValidity("")
    });
</script>
    
