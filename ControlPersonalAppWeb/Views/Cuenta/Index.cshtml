@model IEnumerable<ControlPersonalAppWeb.Cuentas>

@{
    ViewBag.Title = "Cuentas";
    var cuenta = ControlPersonalAppWeb.Utils.SessionManager.CuentaAutenticada();
    var totalCuentas = Model != null ? Model.Count() : 0;
    ViewData["SearchPlaceholder"] = "Buscar por usuario, nombre o correo";
}

<section class="page-header">
    <div>
        <span class="page-header__eyebrow">Módulo Cuentas</span>
        <h1>Cuentas</h1>
        <p>@totalCuentas cuentas disponibles para administrar accesos y mantener usuarios internos.</p>
    </div>

    <div class="page-header__actions">
        @if (cuenta.Permisos.Contains("CuentasC"))
        {
            <a class="btn btn-primary" href="@Url.Action("Create", "Cuenta")">Crear cuenta</a>
        }
    </div>
</section>

<section class="surface">
    <div class="toolbar">
        <div>
            @Html.Partial("Busqueda")
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table table-hover" id="tabla">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Usuario)</th>
                    <th>Contratista</th>
                    <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.Apellido)</th>
                    <th>Correo</th>
                    <th class="data-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Usuario)</td>
                        <td>@Html.DisplayFor(modelItem => item.Empresa)</td>
                        <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td>@Html.DisplayFor(modelItem => item.Apellido)</td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>
                            <div class="table-actions">
                                @if (cuenta.Permisos.Contains("CuentasE"))
                                {
                                    <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Cuenta", new { id = item.Id })">Editar</a>
                                }
                                <a class="btn btn-sm btn-info" href="@Url.Action("Details", "Cuenta", new { id = item.Id })">Detalle</a>
                                @if (cuenta.Permisos.Contains("CuentasD"))
                                {
                                    <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", "Cuenta", new { id = item.Id })" onclick="return confirm('¿Está seguro que desea eliminar la cuenta?');">Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
